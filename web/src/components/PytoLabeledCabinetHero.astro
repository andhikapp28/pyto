---
// Animasi #1 (plan/bab-11-animasi.md): Pyto membawa lemari kecil berlaci
// tiga, label kertas "nama"/"kelas"/"hobi" melayang masuk menempel satu per
// satu, lalu Pyto menepuk laci "hobi" yang terbuka sesaat menunjukkan isinya
// lalu tertutup lagi. Main langsung begitu halaman terbuka (tidak menunggu
// scroll) — sama seperti hero bab-bab sebelumnya. Idle: label kertas
// bergoyang sangat pelan tiap beberapa detik.
import PytoMascotWave from './PytoMascotWave.astro';

const drawers = [
  { label: 'nama', content: 'Kirana' },
  { label: 'kelas', content: '5' },
  { label: 'hobi', content: 'melukis' },
];
---

<div class="cabinet-hero" data-anim="cabinet-hero">
  <PytoMascotWave size={140} />

  <div class="cabinet-hero__cabinet">
    <div class="cabinet-hero__drawers">
      {
        drawers.map((d, i) => (
          <div class={`cabinet-hero__drawer cabinet-hero__drawer--${i + 1}`}>
            <span class="cabinet-hero__tag">{d.label}</span>
            <span class="cabinet-hero__box">
              <span class="cabinet-hero__peek">{d.content}</span>
            </span>
          </div>
        ))
      }
    </div>
    <span class="cabinet-hero__hand" aria-hidden="true">👆</span>
  </div>

  <span class="cabinet-hero__sr">
    Pyto membawa lemari kecil dengan tiga laci berlabel "nama", "kelas", dan "hobi" — laci "hobi"
    terbuka sesaat menunjukkan isinya lalu tertutup lagi.
  </span>
</div>

<style>
  .cabinet-hero {
    position: relative;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    gap: 18px;
    flex-wrap: wrap;
  }

  .cabinet-hero__sr {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
  }

  .cabinet-hero__cabinet {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .cabinet-hero__drawers {
    display: flex;
    gap: 8px;
    padding: 14px 12px;
    background: linear-gradient(var(--wood), var(--wood-dark));
    border: 3px solid var(--wood-border);
    border-radius: 14px;
    box-shadow: 0 6px 14px rgba(154, 99, 41, 0.28);
  }

  .cabinet-hero__drawer {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    opacity: 0;
    transform: translateY(-24px);
  }

  .cabinet-hero.is-in .cabinet-hero__drawer--1 {
    animation: cabinet-hero-drawer-in 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) 0.4s forwards,
      cabinet-hero-wobble 4s ease-in-out 2.2s infinite;
  }

  .cabinet-hero.is-in .cabinet-hero__drawer--2 {
    animation: cabinet-hero-drawer-in 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) 0.75s forwards,
      cabinet-hero-wobble 4s ease-in-out 2.5s infinite;
  }

  .cabinet-hero.is-in .cabinet-hero__drawer--3 {
    animation: cabinet-hero-drawer-in 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) 1.1s forwards,
      cabinet-hero-wobble 4s ease-in-out 2.8s infinite,
      cabinet-hero-tap 0.4s ease 1.9s 2;
  }

  @keyframes cabinet-hero-drawer-in {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes cabinet-hero-wobble {
    0%,
    92%,
    100% {
      transform: rotate(0deg);
    }
    95% {
      transform: rotate(-3deg);
    }
  }

  @keyframes cabinet-hero-tap {
    0%,
    100% {
      transform: scale(1);
    }
    50% {
      transform: scale(1.08);
    }
  }

  .cabinet-hero__tag {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 2px 9px;
    border-radius: 5px;
    background: var(--grape);
    color: #fff;
    font-family: var(--font-code);
    font-weight: 700;
    font-size: 11px;
    transform: rotate(-2deg);
  }

  .cabinet-hero__box {
    position: relative;
    width: 46px;
    height: 36px;
    background: var(--cloud);
    border: 2px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .cabinet-hero__peek {
    font-family: var(--font-code);
    font-size: 10px;
    font-weight: 700;
    color: var(--pyto-green-dark);
    opacity: 0;
  }

  .cabinet-hero.is-in .cabinet-hero__drawer--3 .cabinet-hero__peek {
    animation: cabinet-hero-peek 0.4s ease 2s 2;
  }

  @keyframes cabinet-hero-peek {
    0%,
    100% {
      opacity: 0;
    }
    50% {
      opacity: 1;
    }
  }

  .cabinet-hero__hand {
    position: absolute;
    right: 8px;
    bottom: -18px;
    font-size: 18px;
    opacity: 0;
  }

  .cabinet-hero.is-in .cabinet-hero__hand {
    animation: cabinet-hero-hand-in 0.4s ease 1.7s forwards;
  }

  @keyframes cabinet-hero-hand-in {
    to {
      opacity: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .cabinet-hero__drawer,
    .cabinet-hero__peek,
    .cabinet-hero__hand {
      animation: none !important;
      opacity: 1;
      transform: none;
    }

    .cabinet-hero__peek {
      opacity: 0.85;
    }
  }

  @media (max-width: 480px) {
    .cabinet-hero {
      gap: 10px;
    }
  }
</style>

<script>
  // Hero selalu terlihat begitu halaman dibuka, jadi langsung dipicu (tidak
  // menunggu scroll masuk layar) — sama seperti hero bab-bab sebelumnya.
  document.querySelectorAll('[data-anim="cabinet-hero"]').forEach((el) => {
    setTimeout(() => el.classList.add('is-in'), 200);
  });
</script>
