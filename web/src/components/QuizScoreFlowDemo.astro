---
// Animasi #9 + #10 (plan/bab-10-animasi.md) — Proyek 2: Kuis. Pyto membawa
// papan kuis dengan tiga bintang kosong; skor bertambah satu-satu lewat
// skor = skor + 1 tiap jawaban benar (echo variabel Bab 3 + percabangan Bab
// 6), bintang di papan terisi emas mengikuti skor. Sekali jalan saat
// terlihat, boleh diulang lewat hover/klik/fokus.
---

<div
  class="qsf-demo"
  data-anim="qsf-demo"
  tabindex="0"
  role="button"
  aria-label="Ulangi animasi papan kuis dan skor bertambah"
>
  <div class="qsf-demo__board">
    <span class="qsf-demo__board-icon" aria-hidden="true">📋</span>
    <div class="qsf-demo__stars">
      <span class="qsf-demo__star qsf-demo__star--1">☆</span>
      <span class="qsf-demo__star qsf-demo__star--2">☆</span>
      <span class="qsf-demo__star qsf-demo__star--3">☆</span>
    </div>
  </div>

  <div class="qsf-demo__code">
    <div class="qsf-demo__line"><span class="tok-var">skor</span> = <span class="tok-num">0</span></div>
    <div class="qsf-demo__line">&nbsp;</div>
    <div class="qsf-demo__line">
      <span class="tok-var">jawaban1</span> = <span class="tok-fn">input</span>(<span class="tok-str"
        >&quot;Ibu kota Indonesia? &quot;</span
      >)
    </div>
    <div class="qsf-demo__line">
      <span class="tok-p">if</span> jawaban1 <span class="qsf-demo__eq">==</span> <span class="tok-str"
        >&quot;Jakarta&quot;</span
      >:
    </div>
    <div class="qsf-demo__line qsf-demo__indent">
      skor = skor + <span class="tok-num">1</span> <span class="tok-fn">print</span>(<span class="tok-str"
        >&quot;Benar!&quot;</span
      >)
    </div>
  </div>

  <div class="qsf-demo__flow">
    <span class="qsf-demo__badge">✓ True</span>
    <span class="qsf-demo__arrow" aria-hidden="true">→</span>
    <div class="qsf-demo__score-box">
      <span class="qsf-demo__score-label">skor</span>
      <span class="qsf-demo__score-value qsf-demo__score-value--0">0</span>
      <span class="qsf-demo__score-value qsf-demo__score-value--1">1</span>
    </div>
  </div>
</div>

<p class="qsf-demo__hint">
  💡 Variabel <code>skor</code> yang sama dipakai berulang untuk <strong>menghitung</strong> lewat
  <code>skor = skor + 1</code>. <em>(Klik / hover untuk ulangi.)</em>
</p>

<style>
  .qsf-demo {
    display: flex;
    flex-direction: column;
    gap: 16px;
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-soft);
    padding: 22px 24px;
    cursor: pointer;
  }

  .qsf-demo__board {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
  }

  .qsf-demo__board-icon {
    font-size: 32px;
  }

  .qsf-demo__stars {
    display: flex;
    gap: 6px;
    font-size: 20px;
    color: var(--border);
  }

  .qsf-demo__star--1 {
    transition: color 0.3s ease;
  }

  .qsf-demo.is-in .qsf-demo__star--1 {
    animation: qsf-demo-star-fill 0.4s ease 1.8s forwards;
  }

  @keyframes qsf-demo-star-fill {
    to {
      color: var(--sunny-yellow);
      transform: scale(1.2);
    }
  }

  .qsf-demo__code {
    background: var(--code-bg);
    border-radius: var(--radius-code);
    padding: 14px 16px;
    font-family: var(--font-code);
    font-size: 13.5px;
    line-height: 1.85;
    color: var(--code-text);
    overflow-x: auto;
  }

  .qsf-demo__line {
    white-space: pre-wrap;
  }

  .qsf-demo__indent {
    padding-left: 20px;
  }

  .tok-p {
    color: var(--code-purple);
  }

  .tok-var {
    color: var(--code-red);
  }

  .tok-fn {
    color: var(--code-blue);
  }

  .tok-str {
    color: var(--code-green);
  }

  .tok-num {
    color: var(--code-orange);
  }

  .qsf-demo__eq {
    color: var(--code-green);
  }

  .qsf-demo.is-in .qsf-demo__eq {
    animation: qsf-demo-eq-blink 0.4s ease 0.6s 2;
  }

  @keyframes qsf-demo-eq-blink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.3;
    }
  }

  .qsf-demo__flow {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
  }

  .qsf-demo__badge {
    font-family: var(--font-code);
    font-weight: 700;
    font-size: 13px;
    padding: 4px 10px;
    border-radius: 8px;
    background: var(--pyto-green-soft);
    color: var(--pyto-green-dark);
    opacity: 0;
  }

  .qsf-demo.is-in .qsf-demo__badge {
    animation: qsf-demo-fade-in 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) 1.2s forwards;
  }

  @keyframes qsf-demo-fade-in {
    to {
      opacity: 1;
    }
  }

  .qsf-demo__arrow {
    color: var(--border);
  }

  .qsf-demo__score-box {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    width: 56px;
    height: 56px;
    border-radius: 12px;
    background: var(--box-main-yuk-bg);
    border: 2px solid var(--wood-label-border);
  }

  .qsf-demo__score-label {
    position: absolute;
    top: -18px;
    font-family: var(--font-code);
    font-weight: 700;
    font-size: 11px;
    color: var(--wood-label-text);
  }

  .qsf-demo__score-value {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-code);
    font-weight: 800;
    font-size: 22px;
    color: var(--wood-label-text);
  }

  .qsf-demo__score-value--1 {
    opacity: 0;
  }

  .qsf-demo.is-in .qsf-demo__score-value--0 {
    animation: qsf-demo-fade-out 0.3s ease 1.5s forwards;
  }

  .qsf-demo.is-in .qsf-demo__score-value--1 {
    animation: qsf-demo-pop-in 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) 1.6s forwards;
  }

  @keyframes qsf-demo-fade-out {
    to {
      opacity: 0;
    }
  }

  @keyframes qsf-demo-pop-in {
    0% {
      opacity: 0;
      transform: scale(0.5);
    }
    60% {
      opacity: 1;
      transform: scale(1.3);
    }
    100% {
      opacity: 1;
      transform: scale(1);
    }
  }

  .qsf-demo__hint {
    font-size: 14px;
    line-height: 1.55;
    margin: 0 2px;
    color: var(--slate);
  }

  .qsf-demo__hint code {
    color: var(--pyto-green-dark);
    font-weight: 700;
  }

  @media (prefers-reduced-motion: reduce) {
    .qsf-demo__star--1,
    .qsf-demo__eq,
    .qsf-demo__badge,
    .qsf-demo__score-value--0,
    .qsf-demo__score-value--1 {
      animation: none !important;
    }

    .qsf-demo__star--1 {
      color: var(--sunny-yellow);
    }

    .qsf-demo__badge {
      opacity: 1;
    }

    .qsf-demo__score-value--0 {
      opacity: 0;
    }

    .qsf-demo__score-value--1 {
      opacity: 1;
    }
  }

  @media (max-width: 600px) {
    .qsf-demo__code {
      font-size: 12.5px;
    }
  }
</style>

<script>
  import { observeOnce, wireReplay } from '../scripts/reveal-anim.js';

  const els = document.querySelectorAll('[data-anim="qsf-demo"]');

  observeOnce(els, (el) => {
    el.classList.add('is-in');
  });

  els.forEach((el) => wireReplay(el, 'is-in'));
</script>
