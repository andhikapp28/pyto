---
import PytoMascotWave from './PytoMascotWave.astro';

interface Props {
  number: number;
  title: string;
  tagline: string;
}

const { number, title, tagline } = Astro.props;
---

<div class="chapter-hero" id="top">
  <div class="chapter-hero__stage">
    <PytoMascotWave size={172} />
  </div>
  <span class="badge chapter-hero__badge">BAB {number}</span>
  <h1>{title}</h1>
  <p class="chapter-hero__tagline" set:html={tagline} />
</div>

<style>
  .chapter-hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 14px;
    padding: 12px 0 8px;
    animation: chapter-hero-in 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) both;
  }

  .chapter-hero__stage {
    margin-bottom: 4px;
  }

  .chapter-hero__badge {
    letter-spacing: 0.6px;
  }

  .chapter-hero__tagline {
    color: var(--slate);
    max-width: 480px;
    font-size: 18px;
  }

  @keyframes chapter-hero-in {
    from {
      opacity: 0;
      transform: translateY(32px) scale(0.94);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .chapter-hero {
      animation: none;
    }
  }
</style>
