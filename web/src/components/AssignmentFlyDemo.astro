---
// Animasi #2 & #4 (plan/bab-03-animasi.md): momen assignment `umur = 10`.
// Token nama/=/nilai menyala bergiliran saat kode masuk layar (sama seperti
// pola tok-glow di HaloDuniaDemo), tanda `=` juga berkedip warna dua kali
// (penanda "taruh ke kotak", bukan "sama dengan"), lalu nilainya jatuh
// melayang ke dalam kotak berlabel di sampingnya dan mendarat memantul.
// Sekali jalan saat bagian ini terlihat (observeOnce).
interface Props {
  varName?: string;
  value?: string;
}

const { varName = 'umur', value = '10' } = Astro.props;
---

<div class="asg-fly" data-anim="asg-fly">
  <div class="asg-fly__code card">
    <pre class="asg-fly__pre"><code
      ><span class="asg-fly__line"><span class="tok-var">{varName}</span> <span class="tok-eq asg-fly__eq">=</span> <span class="tok-val">{value}</span></span
      ><span class="asg-fly__line"><span class="tok-fn">print</span>(<span class="tok-var">{varName}</span>)</span
    ></code></pre>
  </div>

  <div class="asg-fly__col">
    <span class="asg-fly__flyer" aria-hidden="true">{value}</span>
    <div class="asg-fly__box">
      <span class="asg-fly__ball" aria-hidden="true">{value}</span>
      <div class="asg-fly__rim"></div>
      <div class="asg-fly__band"></div>
      <div class="asg-fly__label">{varName}</div>
    </div>
    <p class="asg-fly__caption">
      kotak <code>{varName}</code> → {value}
    </p>
  </div>
</div>

<style>
  .asg-fly {
    position: relative;
    display: flex;
    gap: 24px;
    align-items: center;
    flex-wrap: wrap;
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-soft);
    padding: 22px 24px;
  }

  .asg-fly__code {
    flex: 1;
    min-width: 230px;
    background: var(--code-bg);
    border-radius: var(--radius-code);
    padding: 16px 18px;
    overflow-x: auto;
  }

  .asg-fly__pre {
    margin: 0;
    font-family: var(--font-code);
    font-size: 16px;
    line-height: 1.95;
    color: var(--code-text);
  }

  .asg-fly__line {
    display: block;
  }

  .tok-var {
    color: var(--code-red);
    border-radius: 4px;
  }

  .tok-eq {
    color: var(--code-text);
    border-radius: 4px;
  }

  .tok-val {
    color: var(--code-orange);
    border-radius: 4px;
  }

  .tok-fn {
    color: var(--code-blue);
  }

  /* ---- kolom kotak ---- */
  .asg-fly__col {
    position: relative;
    width: 130px;
    flex-shrink: 0;
  }

  .asg-fly__flyer {
    position: absolute;
    left: 50%;
    top: -6px;
    transform: translate(-50%, 0) scale(0.7);
    z-index: 5;
    width: 42px;
    height: 42px;
    border-radius: 50%;
    background: radial-gradient(circle at 34% 30%, #f0b57e, var(--code-orange));
    border: 2px solid #b77b44;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-code);
    font-weight: 700;
    font-size: 17px;
    color: #5a3a16;
    box-shadow: 0 4px 8px rgba(183, 123, 68, 0.5);
    opacity: 0;
  }

  .asg-fly__box {
    position: relative;
    width: 118px;
    height: 100px;
    margin: 44px auto 0;
  }

  .asg-fly__rim {
    position: absolute;
    bottom: 0;
    width: 118px;
    height: 78px;
    border-radius: 10px;
    background: linear-gradient(var(--wood), var(--wood-dark));
    border: 3px solid var(--wood-border);
    box-shadow: 0 6px 14px rgba(154, 99, 41, 0.28);
  }

  .asg-fly__band {
    position: absolute;
    top: 0;
    left: 9px;
    width: 100px;
    height: 14px;
    border-radius: 8px;
    background: var(--wood-label-text);
  }

  .asg-fly__ball {
    position: absolute;
    left: 50%;
    top: -4px;
    transform: translateX(-50%);
    z-index: 3;
    width: 42px;
    height: 42px;
    border-radius: 50%;
    background: radial-gradient(circle at 34% 30%, #f0b57e, var(--code-orange));
    border: 2px solid #b77b44;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-code);
    font-weight: 700;
    font-size: 17px;
    color: #5a3a16;
    opacity: 0;
  }

  .asg-fly__label {
    position: absolute;
    bottom: 14px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 4;
    background: var(--box-main-yuk-bg);
    border: 2px solid var(--wood-label-border);
    color: var(--wood-label-text);
    font-family: var(--font-code);
    font-weight: 700;
    font-size: 14px;
    padding: 3px 12px;
    border-radius: 7px;
    box-shadow: 0 2px 5px rgba(0, 0, 0, 0.12);
  }

  .asg-fly__caption {
    text-align: center;
    font-size: 13px;
    color: var(--slate);
    margin: 8px 0 0;
    font-weight: 600;
  }

  .asg-fly__caption code {
    color: var(--wood-label-text);
  }

  /* ---- animasi (hanya jalan setelah [data-anim].is-in) ---- */
  .asg-fly.is-in .tok-var {
    animation: asg-fly-glow-yellow 0.85s ease 0.15s 1;
  }

  .asg-fly.is-in .asg-fly__eq {
    animation: asg-fly-glow-white 0.85s ease 0.45s 1, asg-fly-eq-blink 0.6s ease 0.9s 2;
  }

  .asg-fly.is-in .tok-val {
    animation: asg-fly-glow-green 0.85s ease 0.75s 1;
  }

  .asg-fly.is-in .asg-fly__flyer {
    animation: asg-fly-value-fly 1.1s cubic-bezier(0.5, 0, 0.4, 1) 0.5s forwards;
  }

  .asg-fly.is-in .asg-fly__ball {
    animation: asg-fly-ball-land 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) 1.35s forwards;
  }

  .asg-fly.is-in .asg-fly__rim {
    animation: asg-fly-box-flash 0.7s ease 1.5s 1;
  }

  @keyframes asg-fly-glow-yellow {
    0%, 100% {
      background: transparent;
    }
    30% {
      background: rgba(255, 201, 77, 0.4);
    }
  }

  @keyframes asg-fly-glow-white {
    0%, 100% {
      background: transparent;
    }
    30% {
      background: rgba(230, 230, 230, 0.35);
    }
  }

  @keyframes asg-fly-glow-green {
    0%, 100% {
      background: transparent;
    }
    30% {
      background: rgba(152, 195, 121, 0.32);
    }
  }

  @keyframes asg-fly-eq-blink {
    0%, 100% {
      color: var(--code-text);
      text-shadow: none;
    }
    40% {
      color: var(--sunny-yellow);
      text-shadow: 0 0 10px rgba(255, 201, 77, 0.9);
    }
  }

  @keyframes asg-fly-value-fly {
    0% {
      opacity: 0;
      transform: translate(-50%, 0) scale(0.7);
    }
    25% {
      opacity: 1;
      transform: translate(-50%, 0) scale(1);
    }
    78% {
      opacity: 1;
      transform: translate(-50%, 74px) scale(1);
    }
    90% {
      transform: translate(-50%, 80px) scale(1);
    }
    100% {
      opacity: 0;
      transform: translate(-50%, 84px) scale(0.9);
    }
  }

  @keyframes asg-fly-ball-land {
    0% {
      opacity: 0;
      transform: translate(-50%, -30px) scale(0.6);
    }
    60% {
      opacity: 1;
      transform: translate(-50%, 3px) scale(1);
    }
    80% {
      transform: translate(-50%, -4px) scale(1);
    }
    100% {
      opacity: 1;
      transform: translate(-50%, 0) scale(1);
    }
  }

  @keyframes asg-fly-box-flash {
    0%, 100% {
      box-shadow: 0 6px 14px rgba(154, 99, 41, 0.28);
    }
    45% {
      box-shadow: 0 0 0 5px rgba(47, 191, 113, 0.45), 0 6px 14px rgba(154, 99, 41, 0.28);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .asg-fly__flyer,
    .asg-fly__ball,
    .tok-var,
    .asg-fly__eq,
    .tok-val,
    .asg-fly__rim {
      animation: none !important;
    }

    .asg-fly__flyer {
      opacity: 0;
    }

    .asg-fly__ball {
      opacity: 1;
      transform: translateX(-50%);
    }
  }

  @media (max-width: 600px) {
    .asg-fly__pre {
      font-size: 14px;
    }
  }
</style>

<script>
  import { observeOnce } from '../scripts/reveal-anim.js';

  observeOnce(document.querySelectorAll('[data-anim="asg-fly"]'), (el) => {
    el.classList.add('is-in');
  });
</script>
