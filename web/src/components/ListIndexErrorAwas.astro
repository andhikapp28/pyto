---
// Animasi #5 (plan/bab-08-animasi.md): teman = ["Kirana", "Budi", "Sari"];
// print(teman[3]) — deretan gerbong dengan nomor 0/1/2, sebuah tangan kecil
// mencoba mengetuk "gerbong nomor 3" yang tidak ada, ketukan memantul kosong
// disertai gelembung IndexError. Dipakai di dalam <KotakAwas>. Sekali jalan
// saat terlihat, boleh diulang lewat hover/klik/fokus.
const items = ['Kirana', 'Budi', 'Sari'];
---

<div
  class="lie-demo"
  data-anim="lie-demo"
  tabindex="0"
  role="button"
  aria-label="Ulangi animasi IndexError karena nomor urut tidak ada"
>
  <div class="lie-demo__code">
    <div class="lie-demo__line">
      <span class="tok-var">teman</span> = [<span class="tok-str">&quot;Kirana&quot;</span>,
      <span class="tok-str">&quot;Budi&quot;</span>, <span class="tok-str">&quot;Sari&quot;</span>]
    </div>
    <div class="lie-demo__line">&nbsp;</div>
    <div class="lie-demo__line">
      <span class="tok-fn">print</span>(teman[<span class="lie-demo__bad-idx">3</span>])
      <span class="lie-demo__comment"># ✗ error — nomor 3 tidak ada!</span>
    </div>
  </div>

  <div class="lie-demo__stage">
    <span class="lie-demo__label">teman</span>
    <div class="lie-demo__cars">
      {
        items.map((label, i) => (
          <div class="lie-demo__col">
            <span class="lie-demo__car">{label}</span>
            <span class="lie-demo__index">{i}</span>
          </div>
        ))
      }
      <div class="lie-demo__col lie-demo__col--ghost">
        <span class="lie-demo__car lie-demo__car--ghost">?</span>
        <span class="lie-demo__index lie-demo__index--ghost">3</span>
      </div>
    </div>

    <div class="lie-demo__error-row">
      <span class="lie-demo__hand" aria-hidden="true">👆</span>
      <span class="lie-demo__error">💥 IndexError</span>
    </div>

    <p class="lie-demo__caption">
      Daftar <code>teman</code> cuma punya 3 barang, jadi nomor urutnya cuma sampai <code>2</code>
      (<code>0, 1, 2</code>) — nomor <code>3</code> belum ada. Cara membaca error kayak gini kita bahas
      tuntas di <strong>Bab 9</strong>.
    </p>
  </div>
</div>

<style>
  .lie-demo {
    display: flex;
    flex-direction: column;
    gap: 16px;
    cursor: pointer;
  }

  .lie-demo__code {
    background: var(--code-bg);
    border-radius: var(--radius-code);
    padding: 14px 16px;
    font-family: var(--font-code);
    font-size: 14px;
    line-height: 1.85;
    color: var(--code-text);
    overflow-x: auto;
  }

  .lie-demo__line {
    white-space: pre;
  }

  .tok-var {
    color: var(--code-red);
  }

  .tok-str {
    color: var(--code-green);
  }

  .tok-fn {
    color: var(--code-blue);
  }

  .lie-demo__comment {
    color: var(--code-comment);
    margin-left: 6px;
  }

  .lie-demo__bad-idx {
    color: var(--coral);
    font-weight: 700;
  }

  .lie-demo__stage {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
  }

  .lie-demo__label {
    font-family: var(--font-code);
    font-weight: 700;
    font-size: 13px;
    color: var(--slate);
  }

  .lie-demo__cars {
    display: flex;
    gap: 4px;
    align-items: flex-end;
  }

  .lie-demo__col {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
  }

  .lie-demo__car {
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--code-green);
    color: #1e3a16;
    border: 2px solid #7bae58;
    border-radius: 8px;
    padding: 8px 12px;
    font-family: var(--font-code);
    font-weight: 700;
    font-size: 14px;
  }

  .lie-demo__index {
    font-family: var(--font-code);
    font-weight: 800;
    font-size: 13px;
    color: var(--slate);
    width: 22px;
    height: 22px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--cloud);
  }

  .lie-demo__car--ghost {
    background: transparent;
    border: 2px dashed var(--border);
    color: var(--border);
  }

  .lie-demo__index--ghost {
    background: transparent;
    border: 2px dashed var(--border);
    color: var(--coral);
  }

  .lie-demo__error-row {
    display: flex;
    align-items: center;
    gap: 8px;
    opacity: 0;
  }

  .lie-demo.is-in .lie-demo__error-row {
    animation: lie-demo-fade-in 0.4s ease 0.6s forwards;
  }

  .lie-demo.is-in .lie-demo__hand {
    animation: lie-demo-tap 0.4s ease 0.6s;
  }

  @keyframes lie-demo-tap {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(6px);
    }
  }

  .lie-demo__hand {
    font-size: 20px;
  }

  .lie-demo__error {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: var(--code-error-bg);
    border: 1px solid var(--code-error-border);
    border-radius: 8px;
    padding: 5px 12px;
    color: var(--code-error-text);
    font-weight: 700;
    font-size: 13px;
  }

  .lie-demo__caption {
    max-width: 420px;
    text-align: center;
    font-size: 13px;
    color: var(--ink);
    margin: 0;
    opacity: 0;
  }

  .lie-demo.is-in .lie-demo__caption {
    animation: lie-demo-fade-in 0.4s ease 1s forwards;
  }

  @keyframes lie-demo-fade-in {
    to {
      opacity: 1;
    }
  }

  .lie-demo__caption code {
    color: var(--pyto-green-dark);
    font-weight: 700;
  }

  @media (prefers-reduced-motion: reduce) {
    .lie-demo__error-row,
    .lie-demo__hand,
    .lie-demo__caption {
      animation: none !important;
    }

    .lie-demo__error-row,
    .lie-demo__caption {
      opacity: 1;
    }
  }
</style>

<script>
  import { observeOnce, wireReplay } from '../scripts/reveal-anim.js';

  const els = document.querySelectorAll('[data-anim="lie-demo"]');

  observeOnce(els, (el) => {
    el.classList.add('is-in');
  });

  els.forEach((el) => wireReplay(el, 'is-in'));
</script>
