<section class="footer-cta">
  <div class="container footer-cta__inner">
    <span class="footer-cta__emoji" aria-hidden="true">🐍🤖</span>
    <h2>Siap jadi programmer cilik?</h2>
    <a href="#bab-1" class="btn btn-white">Mulai dari Bab 1 sekarang →</a>
  </div>
</section>

<style>
  .footer-cta {
    background: linear-gradient(135deg, var(--pyto-green) 0%, var(--pyto-green-dark) 100%);
  }

  .footer-cta__inner {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
  }

  .footer-cta__emoji {
    font-size: 56px;
    display: inline-block;
    animation: wiggle 2.4s ease-in-out infinite;
  }

  @keyframes wiggle {
    0%,
    100% {
      transform: rotate(-6deg);
    }
    50% {
      transform: rotate(6deg);
    }
  }

  .footer-cta h2 {
    color: var(--white);
  }

  @media (prefers-reduced-motion: reduce) {
    .footer-cta__emoji {
      animation: none;
    }
  }
</style>
