---
// Animasi #2 (plan/bab-01-animasi.md): analogi "pembantu ajaib" — gelembung
// perintah melayang dari anak ke robot, robot "berpikir", lalu hasil muncul.
// Urutan ini dipicu sekali saat bagian ini ~30% terlihat di layar (lewat
// observeOnce), tapi begitu terpicu, ketiga animasinya lalu BERULANG TERUS
// (infinite) selama komponen ini terpasang di halaman — bukan main sekali
// lalu berhenti. Ketiganya berbagi satu siklus 4 detik yang sudah disusun
// selaras (lihat keyframe di bawah): gelembung melayang → robot berpikir →
// hasil muncul → diam sejenak (~1,2 detik) → lalu mengulang dari awal.
---

<div class="magic-helper" data-anim="magic" data-reveal>
  <p class="magic-helper__caption">Coding = memberi perintah, lalu dapat hasil</p>

  <div class="magic-helper__stage">
    <div class="magic-helper__person">
      <span class="magic-helper__emoji" aria-hidden="true">🧒</span>
      <span class="magic-helper__label">Kamu</span>
    </div>

    <div class="magic-helper__track" aria-hidden="true">
      <span class="magic-helper__bubble">🧒 "Hitung 2 + 2"</span>
    </div>

    <div class="magic-helper__person">
      <span class="magic-helper__emoji magic-helper__robot" aria-hidden="true">🤖</span>
      <span class="magic-helper__label">Komputer</span>
      <span class="magic-helper__result" aria-hidden="true">4</span>
    </div>
  </div>

  <p class="magic-helper__sr">
    Kamu memberi perintah "Hitung 2 + 2" ke komputer, lalu komputer menjawab "4".
  </p>
</div>

<style>
  .magic-helper {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
    text-align: center;
  }

  .magic-helper__caption {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 18px;
    color: var(--pyto-green-dark);
  }

  .magic-helper__stage {
    display: flex;
    align-items: center;
    gap: 24px;
    width: 100%;
    max-width: 460px;
  }

  .magic-helper__person {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    flex-shrink: 0;
  }

  .magic-helper__emoji {
    font-size: 48px;
  }

  .magic-helper__label {
    font-size: 14px;
    font-weight: 700;
    color: var(--slate);
  }

  .magic-helper__track {
    position: relative;
    flex: 1;
    height: 2px;
    background: repeating-linear-gradient(
      to right,
      var(--border) 0 8px,
      transparent 8px 14px
    );
  }

  .magic-helper__bubble {
    position: absolute;
    top: -20px;
    left: 0;
    white-space: nowrap;
    background: var(--white);
    border: 1px solid var(--border);
    box-shadow: var(--shadow-soft);
    font-family: var(--font-code);
    font-size: 13px;
    padding: 6px 12px;
    border-radius: 999px;
  }

  .magic-helper__result {
    position: absolute;
    top: -10px;
    right: -10px;
    width: 34px;
    height: 34px;
    border-radius: 999px;
    background: var(--pyto-green);
    color: var(--white);
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 6px 14px rgba(47, 191, 113, 0.35);
  }

  .magic-helper__sr {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
  }

  /* Sembunyikan lebih dulu HANYA kalau JS reveal sudah pasti aktif (lihat
     global.css .js-reveal). Kalau JS gagal, semuanya tetap terlihat. */
  :global(.js-reveal) .magic-helper__bubble,
  :global(.js-reveal) .magic-helper__result {
    opacity: 0;
  }

  /* Satu siklus 4 detik dipakai bersama oleh ketiga animasi supaya urutannya
     tetap selaras di setiap putaran: melayang (0-40%) → robot berpikir
     (32-48%) → hasil muncul (48-64%) → diam ~1,2 detik (64-94%) → memudar
     balik ke awal (94-100%) sebelum mengulang. */
  :global(.js-reveal) .magic-helper.is-in .magic-helper__bubble {
    animation: magic-bubble-travel 4s ease infinite;
  }

  :global(.js-reveal) .magic-helper.is-in .magic-helper__result {
    animation: magic-result-pop 4s ease infinite;
  }

  :global(.js-reveal) .magic-helper.is-in .magic-helper__robot {
    animation: magic-robot-think 4s ease infinite;
  }

  @keyframes magic-bubble-travel {
    0% {
      transform: translateX(0) scale(0.6);
      opacity: 0;
    }
    7% {
      opacity: 1;
      transform: translateX(0) scale(1);
    }
    35% {
      opacity: 1;
      transform: translateX(calc(100% - 20px)) scale(1);
    }
    40%,
    100% {
      opacity: 0;
      transform: translateX(calc(100% - 20px)) scale(0.7);
    }
  }

  @keyframes magic-result-pop {
    0%,
    48% {
      transform: scale(0);
      opacity: 0;
    }
    56% {
      transform: scale(1.15);
      opacity: 1;
    }
    60% {
      transform: scale(0.95);
      opacity: 1;
    }
    64%,
    94% {
      transform: scale(1);
      opacity: 1;
    }
    99% {
      transform: scale(0.85);
      opacity: 0;
    }
    100% {
      transform: scale(0);
      opacity: 0;
    }
  }

  @keyframes magic-robot-think {
    0%,
    32%,
    48%,
    100% {
      transform: rotate(0);
    }
    38% {
      transform: rotate(-5deg);
    }
    44% {
      transform: rotate(5deg);
    }
  }

  /* Pengaman tambahan: kalau prefers-reduced-motion aktif, jangan biarkan
     animasi "infinite" ini berputar (walau global.css sudah memaksa durasi
     ~0 dan iterasi 1x, itu tetap bisa membuat urutan sempat "berkedip" ke
     status tersembunyi di batas siklus). Tampilkan langsung status akhir
     yang statis: gelembung sudah terkirim (sembunyi), hasil "4" tampil. */
  @media (prefers-reduced-motion: reduce) {
    .magic-helper__bubble,
    .magic-helper__result,
    .magic-helper__robot {
      animation: none !important;
    }

    .magic-helper__result {
      opacity: 1;
      transform: scale(1);
    }
  }

  @media (max-width: 560px) {
    .magic-helper__stage {
      gap: 12px;
    }

    .magic-helper__bubble {
      font-size: 12px;
      padding: 5px 10px;
    }
  }
</style>

<script>
  import { observeOnce } from '../scripts/reveal-anim.js';

  observeOnce(document.querySelectorAll('[data-anim="magic"]'), (el) => {
    el.classList.add('is-in');
  });
</script>
