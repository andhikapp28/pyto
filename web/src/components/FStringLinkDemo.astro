---
// Animasi #6 (plan/bab-03-animasi.md): sambungan ke f-string Bab 2. Kotak
// berlabel memancarkan garis cahaya menuju token {umur} di dalam f-string,
// token itu menyala, lalu di area "Hasil di layar" placeholder {umur}
// memudar berganti jadi nilai aslinya. Sekali jalan saat terlihat, boleh
// diulang dengan hover/klik (sama seperti ReassignmentDemo).
interface Props {
  varName?: string;
  value?: string;
  template?: string;
  suffix?: string;
}

const { varName = 'umur', value = '10', template = 'Umurku ', suffix = ' tahun' } = Astro.props;
const token = `{${varName}}`;
---

<div class="fsx" data-anim="fsx" tabindex="0" role="button" aria-label="Ulangi animasi sambungan f-string">
  <div class="fsx__box-col">
    <div class="fsx__box">
      <div class="fsx__rim"></div>
      <span class="fsx__ball" aria-hidden="true">{value}</span>
      <span class="fsx__label" aria-hidden="true">{varName}</span>
    </div>
    <div class="fsx__beam" aria-hidden="true"></div>
  </div>

  <div class="fsx__right">
    <div class="fsx__code card">
      <pre class="fsx__pre"><code
        ><span class="fsx__line"><span class="tok-var">{varName}</span> <span class="tok-eq">=</span> <span class="tok-val">{value}</span></span
        ><span class="fsx__line"><span class="tok-fn">print</span>(<span class="tok-fprefix">f</span><span class="tok-str">&quot;{template}<span class="fsx__tok">{token}</span>{suffix}&quot;</span>)</span
      ></code></pre>
    </div>

    <div class="fsx__result card">
      <span class="fsx__result-label">Hasil di layar:</span>
      <p class="fsx__result-line">
        {template}<span class="fsx__slot"
          ><span class="fsx__ph" aria-hidden="true">{token}</span><span class="fsx__val" data-value>{value}</span><span
            class="fsx__spacer">{value}</span
          ></span
        >{suffix}
      </p>
    </div>
  </div>
</div>

<style>
  .fsx {
    position: relative;
    display: flex;
    gap: 22px;
    align-items: center;
    flex-wrap: wrap;
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-soft);
    padding: 22px 24px;
    cursor: pointer;
  }

  /* ---- kotak ---- */
  .fsx__box-col {
    position: relative;
    flex-shrink: 0;
    width: 110px;
    text-align: center;
  }

  .fsx__box {
    position: relative;
    width: 100px;
    height: 82px;
    margin: 0 auto;
  }

  .fsx__rim {
    position: absolute;
    bottom: 0;
    width: 100px;
    height: 64px;
    border-radius: 9px;
    background: linear-gradient(var(--wood), var(--wood-dark));
    border: 3px solid var(--wood-border);
  }

  .fsx__ball {
    position: absolute;
    left: 50%;
    top: 2px;
    transform: translateX(-50%);
    z-index: 3;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: radial-gradient(circle at 34% 30%, #f0b57e, var(--code-orange));
    border: 2px solid #b77b44;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-code);
    font-weight: 700;
    font-size: 15px;
    color: #5a3a16;
  }

  .fsx__label {
    position: absolute;
    bottom: 12px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 4;
    background: var(--box-main-yuk-bg);
    border: 2px solid var(--wood-label-border);
    color: var(--wood-label-text);
    font-family: var(--font-code);
    font-weight: 700;
    font-size: 12px;
    padding: 2px 9px;
    border-radius: 6px;
  }

  .fsx__beam {
    position: absolute;
    right: -22px;
    top: 34px;
    width: 34px;
    height: 4px;
    border-radius: 2px;
    background: linear-gradient(90deg, var(--sunny-yellow), rgba(255, 201, 77, 0));
    opacity: 0;
    transform-origin: left center;
    transform: scaleX(0);
  }

  /* ---- kanan: kode + hasil ---- */
  .fsx__right {
    flex: 1;
    min-width: 230px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .fsx__code {
    background: var(--code-bg);
    border-radius: var(--radius-code);
    padding: 16px 18px;
    overflow-x: auto;
  }

  .fsx__pre {
    margin: 0;
    font-family: var(--font-code);
    font-size: 15px;
    line-height: 1.95;
    color: var(--code-text);
  }

  .fsx__line {
    display: block;
  }

  .tok-var {
    color: var(--code-red);
  }

  .tok-eq {
    color: var(--code-text);
  }

  .tok-val {
    color: var(--code-orange);
  }

  .tok-fn {
    color: var(--code-blue);
  }

  .tok-fprefix {
    color: var(--code-purple);
    font-weight: 700;
  }

  .tok-str {
    color: var(--code-green);
  }

  .fsx__tok {
    color: var(--sunny-yellow);
    background: rgba(255, 201, 77, 0.16);
    border-radius: 4px;
  }

  .fsx__result {
    background: var(--cloud);
    border: 1px solid var(--border);
    border-radius: var(--radius-code);
    padding: 12px 16px;
  }

  .fsx__result-label {
    display: block;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.4px;
    text-transform: uppercase;
    color: var(--slate);
    margin-bottom: 5px;
  }

  .fsx__result-line {
    margin: 0;
    font-family: var(--font-code);
    font-size: 16px;
    color: var(--ink);
  }

  .fsx__slot {
    position: relative;
    display: inline-block;
    min-width: 44px;
    text-align: left;
    vertical-align: bottom;
  }

  .fsx__ph {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    color: var(--wood-label-text);
    background: rgba(255, 201, 77, 0.22);
    border-radius: 5px;
    padding: 0 3px;
    white-space: nowrap;
  }

  .fsx__val {
    position: absolute;
    left: 50%;
    transform: translateX(-50%) scale(0.55);
    color: var(--pyto-green-dark);
    font-weight: 700;
    opacity: 0;
  }

  .fsx__spacer {
    visibility: hidden;
  }

  /* ---- animasi ---- */
  .fsx.is-in .fsx__beam {
    animation: fsx-beam-grow 1.1s ease 0.3s forwards;
  }

  .fsx.is-in .fsx__tok {
    animation: fsx-tok-morph 0.8s ease 0.6s 1;
  }

  .fsx.is-in .fsx__ph {
    animation: fsx-ph-out 0.3s ease 1.1s forwards;
  }

  .fsx.is-in .fsx__val {
    animation: fsx-val-in 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) 1.2s forwards;
  }

  @keyframes fsx-beam-grow {
    0% {
      opacity: 0;
      transform: scaleX(0);
    }
    30% {
      opacity: 1;
    }
    100% {
      opacity: 0;
      transform: scaleX(1);
    }
  }

  @keyframes fsx-tok-morph {
    0% {
      background: rgba(255, 201, 77, 0.16);
    }
    50% {
      background: rgba(255, 201, 77, 0.5);
    }
    100% {
      background: rgba(255, 201, 77, 0.16);
    }
  }

  @keyframes fsx-ph-out {
    to {
      opacity: 0;
    }
  }

  @keyframes fsx-val-in {
    0% {
      opacity: 0;
      transform: translateX(-50%) scale(0.55);
    }
    100% {
      opacity: 1;
      transform: translateX(-50%) scale(1);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .fsx__beam,
    .fsx__tok,
    .fsx__ph,
    .fsx__val {
      animation: none !important;
    }

    .fsx__beam {
      opacity: 0;
    }

    .fsx__ph {
      opacity: 0;
    }

    .fsx__val {
      opacity: 1;
      transform: translateX(-50%);
    }
  }

  @media (max-width: 600px) {
    .fsx__pre {
      font-size: 14px;
    }
  }
</style>

<script>
  import { observeOnce } from '../scripts/reveal-anim.js';

  const els = document.querySelectorAll('[data-anim="fsx"]');

  observeOnce(els, (el) => {
    el.classList.add('is-in');
  });

  els.forEach((el) => {
    const replay = () => {
      el.classList.remove('is-in');
      void el.offsetWidth;
      el.classList.add('is-in');
    };
    el.addEventListener('mouseenter', replay);
    el.addEventListener('click', replay);
    el.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        replay();
      }
    });
  });
</script>
