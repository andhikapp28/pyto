---
// Animasi #8 (plan/bab-12-animasi.md, kotak "Tahu Lebih"): versi ringan dari
// FetchJsonDemo dengan tujuan "Dog CEO API" — amplop balasan, begitu
// dibuka, menunjukkan siluet anjing acak. Sekali jalan saat terlihat, boleh
// diulang lewat hover/klik/fokus.
const dogs = ['🐕', '🐶', '🐩'];
---

<div
  class="dad-demo"
  data-anim="dad-demo"
  tabindex="0"
  role="button"
  aria-label="Ulangi animasi memanggil Dog CEO API"
>
  <div class="dad-demo__code">
    <div class="dad-demo__line">
      <span class="tok-var">respons</span> = <span class="tok-p">await</span>
      <span class="tok-fn">pyfetch</span>(<span class="tok-str"
        >&quot;https://dog.ceo/api/breeds/image/random&quot;</span
      >)
    </div>
    <div class="dad-demo__line">
      <span class="tok-var">data</span> = <span class="tok-p">await</span> respons.<span
        class="tok-fn">json</span
      >()
    </div>
    <div class="dad-demo__line"><span class="tok-fn">print</span>(data[<span class="tok-str">&quot;message&quot;</span>])</div>
  </div>

  <div class="dad-demo__stage">
    <span class="dad-demo__cloud">☁️ Dog CEO API</span>
    <span class="dad-demo__envelope" aria-hidden="true">📩</span>
    <div class="dad-demo__dogs" aria-hidden="true">
      {dogs.map((d, i) => <span class={`dad-demo__dog dad-demo__dog--${i}`}>{d}</span>)}
    </div>
  </div>
</div>

<p class="dad-demo__hint">
  💡 Sama persis polanya seperti cuaca — cuma alamat dan isi labelnya yang beda.
  <em>(Klik / hover untuk ulangi.)</em>
</p>

<style>
  .dad-demo {
    display: flex;
    flex-direction: column;
    gap: 14px;
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-soft);
    padding: 20px 22px;
    cursor: pointer;
  }

  .dad-demo__code {
    background: var(--code-bg);
    border-radius: var(--radius-code);
    padding: 14px 16px;
    font-family: var(--font-code);
    font-size: 12px;
    line-height: 1.8;
    color: var(--code-text);
    overflow-x: auto;
  }

  .dad-demo__line {
    white-space: pre;
  }

  .tok-p {
    color: var(--code-purple);
  }

  .tok-var {
    color: var(--code-red);
  }

  .tok-fn {
    color: var(--code-blue);
  }

  .tok-str {
    color: var(--code-green);
  }

  .dad-demo__stage {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .dad-demo__cloud {
    font-family: var(--font-code);
    font-weight: 700;
    font-size: 12px;
    background: var(--box-tahu-lebih-bg);
    border: 1px solid var(--sky-blue);
    border-radius: 999px;
    padding: 4px 12px;
  }

  .dad-demo__envelope {
    font-size: 20px;
    opacity: 0;
  }

  .dad-demo.is-in .dad-demo__envelope {
    animation: dad-demo-fade-in 0.4s ease 0.5s forwards;
  }

  @keyframes dad-demo-fade-in {
    to {
      opacity: 1;
    }
  }

  .dad-demo__dogs {
    display: flex;
    gap: 6px;
  }

  .dad-demo__dog {
    font-size: 24px;
    opacity: 0;
    transform: scale(0.5);
  }

  .dad-demo.is-in .dad-demo__dog--0 {
    animation: dad-demo-pop 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) 1s forwards;
  }

  .dad-demo.is-in .dad-demo__dog--1 {
    animation: dad-demo-pop 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) 1.35s forwards;
  }

  .dad-demo.is-in .dad-demo__dog--2 {
    animation: dad-demo-pop 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) 1.7s forwards;
  }

  @keyframes dad-demo-pop {
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  .dad-demo__hint {
    font-size: 14px;
    line-height: 1.55;
    margin: 0 2px;
    color: var(--slate);
  }

  @media (prefers-reduced-motion: reduce) {
    .dad-demo__envelope,
    .dad-demo__dog {
      animation: none !important;
      opacity: 1;
      transform: none;
    }
  }
</style>

<script>
  import { observeOnce, wireReplay } from '../scripts/reveal-anim.js';

  const els = document.querySelectorAll('[data-anim="dad-demo"]');

  observeOnce(els, (el) => {
    el.classList.add('is-in');
  });

  els.forEach((el) => wireReplay(el, 'is-in'));
</script>
