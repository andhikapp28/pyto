---
// Animasi #5 (plan/bab-11-animasi.md): murid = {"nama": "Kirana", "kelas":
// 5}; print(murid["umur"]) — lemari cuma punya dua laci, tangan kecil
// mengetuk-ngetuk mencari laci "umur" yang tidak ada, meraba kosong dan
// memantul, disertai gelembung KeyError. Dipakai di dalam <KotakAwas>.
// Sekali jalan saat terlihat, boleh diulang lewat hover/klik/fokus.
---

<div
  class="dke-demo"
  data-anim="dke-demo"
  tabindex="0"
  role="button"
  aria-label="Ulangi animasi KeyError karena label tidak ada"
>
  <div class="dke-demo__code">
    <div class="dke-demo__line">
      <span class="tok-var">murid</span> = {'{'}<span class="tok-str">&quot;nama&quot;</span>:
      <span class="tok-str">&quot;Kirana&quot;</span>, <span class="tok-str">&quot;kelas&quot;</span>: 5{'}'}
    </div>
    <div class="dke-demo__line">&nbsp;</div>
    <div class="dke-demo__line">
      <span class="tok-fn">print</span>(murid[<span class="dke-demo__bad-key">&quot;umur&quot;</span>])
      <span class="dke-demo__comment"># ✗ label "umur" belum ada!</span>
    </div>
  </div>

  <div class="dke-demo__stage">
    <span class="dke-demo__cabinet-label">murid</span>
    <div class="dke-demo__cabinet">
      <div class="dke-demo__drawer">
        <span class="dke-demo__tag">nama</span>
        <span class="dke-demo__box">Kirana</span>
      </div>
      <div class="dke-demo__drawer">
        <span class="dke-demo__tag">kelas</span>
        <span class="dke-demo__box">5</span>
      </div>
      <div class="dke-demo__drawer dke-demo__drawer--ghost">
        <span class="dke-demo__tag dke-demo__tag--ghost">umur?</span>
        <span class="dke-demo__box dke-demo__box--ghost">?</span>
      </div>
    </div>

    <div class="dke-demo__error-row">
      <span class="dke-demo__hand" aria-hidden="true">👆</span>
      <span class="dke-demo__error">💥 KeyError: 'umur'</span>
    </div>

    <p class="dke-demo__caption">
      Lemari <code>murid</code> cuma punya laci <code>nama</code> dan <code>kelas</code> — laci
      <code>umur</code> memang belum pernah dibuat. Beda dari <code>IndexError</code> di Bab 8: di
      sana masalahnya nomor, di sini masalahnya nama labelnya.
    </p>
  </div>
</div>

<style>
  .dke-demo {
    display: flex;
    flex-direction: column;
    gap: 16px;
    cursor: pointer;
  }

  .dke-demo__code {
    background: var(--code-bg);
    border-radius: var(--radius-code);
    padding: 14px 16px;
    font-family: var(--font-code);
    font-size: 13px;
    line-height: 1.85;
    color: var(--code-text);
    overflow-x: auto;
  }

  .dke-demo__line {
    white-space: pre;
  }

  .tok-var {
    color: var(--code-red);
  }

  .tok-str {
    color: var(--code-green);
  }

  .tok-fn {
    color: var(--code-blue);
  }

  .dke-demo__comment {
    color: var(--code-comment);
    margin-left: 6px;
  }

  .dke-demo__bad-key {
    color: var(--coral);
    font-weight: 700;
  }

  .dke-demo__stage {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
  }

  .dke-demo__cabinet-label {
    font-family: var(--font-code);
    font-weight: 700;
    font-size: 13px;
    color: var(--slate);
  }

  .dke-demo__cabinet {
    display: flex;
    gap: 10px;
    padding: 16px 14px;
    background: linear-gradient(var(--wood), var(--wood-dark));
    border: 3px solid var(--wood-border);
    border-radius: 14px;
    box-shadow: 0 6px 14px rgba(154, 99, 41, 0.28);
  }

  .dke-demo__drawer {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
  }

  .dke-demo__tag {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 2px 9px;
    border-radius: 5px;
    background: var(--grape);
    color: #fff;
    font-family: var(--font-code);
    font-weight: 700;
    font-size: 11px;
  }

  .dke-demo__box {
    width: 62px;
    height: 36px;
    background: var(--cloud);
    border: 2px solid var(--border);
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-code);
    font-size: 11px;
    font-weight: 700;
    color: var(--pyto-green-dark);
  }

  .dke-demo__tag--ghost {
    background: transparent;
    border: 2px dashed var(--border);
    color: var(--coral);
  }

  .dke-demo__box--ghost {
    background: transparent;
    border: 2px dashed var(--border);
    color: var(--border);
  }

  .dke-demo__error-row {
    display: flex;
    align-items: center;
    gap: 8px;
    opacity: 0;
  }

  .dke-demo.is-in .dke-demo__error-row {
    animation: dke-demo-fade-in 0.4s ease 0.6s forwards;
  }

  .dke-demo.is-in .dke-demo__hand {
    animation: dke-demo-tap 0.4s ease 0.6s;
  }

  @keyframes dke-demo-tap {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(6px);
    }
  }

  .dke-demo__hand {
    font-size: 20px;
  }

  .dke-demo__error {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: var(--code-error-bg);
    border: 1px solid var(--code-error-border);
    border-radius: 8px;
    padding: 5px 12px;
    color: var(--code-error-text);
    font-weight: 700;
    font-size: 13px;
  }

  .dke-demo__caption {
    max-width: 440px;
    text-align: center;
    font-size: 13px;
    color: var(--ink);
    margin: 0;
    opacity: 0;
  }

  .dke-demo.is-in .dke-demo__caption {
    animation: dke-demo-fade-in 0.4s ease 1s forwards;
  }

  @keyframes dke-demo-fade-in {
    to {
      opacity: 1;
    }
  }

  .dke-demo__caption code {
    color: var(--pyto-green-dark);
    font-weight: 700;
  }

  @media (prefers-reduced-motion: reduce) {
    .dke-demo__error-row,
    .dke-demo__hand,
    .dke-demo__caption {
      animation: none !important;
    }

    .dke-demo__error-row,
    .dke-demo__caption {
      opacity: 1;
    }
  }
</style>

<script>
  import { observeOnce, wireReplay } from '../scripts/reveal-anim.js';

  const els = document.querySelectorAll('[data-anim="dke-demo"]');

  observeOnce(els, (el) => {
    el.classList.add('is-in');
  });

  els.forEach((el) => wireReplay(el, 'is-in'));
</script>
