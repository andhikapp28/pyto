<section class="pyto-quote">
  <div class="container">
    <div class="pyto-quote__box" data-reveal>
      <span class="pyto-quote__mascot" role="img" aria-label="Pyto">🐍</span>
      <p class="pyto-quote__text">
        "Halo! Aku Pyto, namaku diambil dari Python. Aku akan menemanimu di setiap
        bab. Kalau ada kata sulit, aku yang jelaskan. Ayo mulai!"
      </p>
    </div>
  </div>
</section>

<style>
  .pyto-quote {
    background: var(--white);
    padding-block: var(--section-spacing);
  }

  .pyto-quote__box {
    background: var(--pyto-green-soft);
    border-radius: var(--radius-card);
    padding: 40px;
    display: flex;
    align-items: center;
    gap: 32px;
    max-width: 880px;
    margin-inline: auto;
  }

  .pyto-quote__mascot {
    font-size: 88px;
    flex-shrink: 0;
  }

  .pyto-quote__text {
    font-family: var(--font-heading);
    font-size: 22px;
    font-weight: 600;
    color: var(--pyto-green-dark);
    line-height: 1.5;
  }

  @media (max-width: 700px) {
    .pyto-quote__box {
      flex-direction: column;
      text-align: center;
      padding: 32px 24px;
    }

    .pyto-quote__text {
      font-size: 19px;
    }
  }
</style>
