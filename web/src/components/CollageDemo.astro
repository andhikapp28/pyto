---
// Animasi #8 (plan/bab-13-animasi.md, kotak "Tahu Lebih"): kanvas kosong
// dari Image.new(...) muncul, foto kecil berwarna ditempel ke kiri, versi
// hitam-putihnya ditempel ke kanan — hasil akhir kolase "Sebelum/Sesudah".
// Sekali jalan saat terlihat, boleh diulang lewat hover/klik/fokus.
---

<div
  class="col-demo"
  data-anim="col-demo"
  tabindex="0"
  role="button"
  aria-label="Ulangi animasi membuat kolase sebelum/sesudah"
>
  <div class="col-demo__code">
    <div class="col-demo__line">
      <span class="tok-var">kolase</span> = Image.<span class="tok-fn">new</span>(<span class="tok-str"
        >&quot;RGB&quot;</span
      >, (400, 200))
    </div>
    <div class="col-demo__line">kolase.<span class="tok-fn">paste</span>(kecil, (0, 0))</div>
    <div class="col-demo__line">kolase.<span class="tok-fn">paste</span>(abu, (200, 0))</div>
  </div>

  <div class="col-demo__stage">
    <div class="col-demo__canvas">
      <span class="col-demo__half col-demo__half--color" aria-hidden="true">
        <span class="col-demo__sun"></span>
      </span>
      <span class="col-demo__half col-demo__half--gray" aria-hidden="true">
        <span class="col-demo__sun col-demo__sun--gray"></span>
      </span>
    </div>
    <span class="col-demo__caption">Sebelum/Sesudah</span>
  </div>
</div>

<p class="col-demo__hint">
  💡 Kanvas kosong, lalu tempel satu-satu — begitu saja kamu punya kolase.
  <em>(Klik / hover untuk ulangi.)</em>
</p>

<style>
  .col-demo {
    display: flex;
    flex-direction: column;
    gap: 16px;
    cursor: pointer;
  }

  .col-demo__code {
    background: var(--code-bg);
    border-radius: var(--radius-code);
    padding: 14px 16px;
    font-family: var(--font-code);
    font-size: 12px;
    line-height: 1.8;
    color: var(--code-text);
    overflow-x: auto;
  }

  .col-demo__line {
    white-space: pre;
  }

  .tok-var {
    color: var(--code-red);
  }

  .tok-fn {
    color: var(--code-blue);
  }

  .tok-str {
    color: var(--code-green);
  }

  .col-demo__stage {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }

  .col-demo__canvas {
    display: flex;
    width: 160px;
    height: 80px;
    border-radius: 6px;
    overflow: hidden;
    border: 1px solid var(--border);
    background: #fff;
  }

  .col-demo__half {
    position: relative;
    width: 50%;
    height: 100%;
    opacity: 0;
    transform: scale(0.8);
  }

  .col-demo__half--color {
    background: linear-gradient(180deg, var(--sky-blue) 0%, #cfe9ff 100%);
  }

  .col-demo__half--gray {
    background: linear-gradient(180deg, #cfcfcf 0%, #8f8f8f 100%);
  }

  .col-demo.is-in .col-demo__half--color {
    animation: col-demo-paste-in 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) 0.5s forwards;
  }

  .col-demo.is-in .col-demo__half--gray {
    animation: col-demo-paste-in 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) 1.1s forwards;
  }

  @keyframes col-demo-paste-in {
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  .col-demo__sun {
    position: absolute;
    top: 6px;
    right: 8px;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--sunny-yellow);
  }

  .col-demo__sun--gray {
    background: #d8d8d8;
  }

  .col-demo__caption {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 12px;
    color: var(--slate);
    opacity: 0;
  }

  .col-demo.is-in .col-demo__caption {
    animation: col-demo-fade-in 0.4s ease 1.5s forwards;
  }

  @keyframes col-demo-fade-in {
    to {
      opacity: 1;
    }
  }

  .col-demo__hint {
    font-size: 14px;
    line-height: 1.55;
    margin: 0 2px;
    color: var(--slate);
  }

  @media (prefers-reduced-motion: reduce) {
    .col-demo__half,
    .col-demo__caption {
      animation: none !important;
      opacity: 1;
      transform: none;
    }
  }
</style>

<script>
  import { observeOnce, wireReplay } from '../scripts/reveal-anim.js';

  const els = document.querySelectorAll('[data-anim="col-demo"]');

  observeOnce(els, (el) => {
    el.classList.add('is-in');
  });

  els.forEach((el) => wireReplay(el, 'is-in'));
</script>
