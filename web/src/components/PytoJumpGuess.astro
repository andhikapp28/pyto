---
// Animasi #7 (plan/bab-07-animasi.md) — kartu "Main Yuk: Pyto Loncat 5
// Kali". Pembaca mengisi angka di bagian kosong latihan (range(___)); tiap
// kali ia mengetes tebakannya, mini-Pyto melompat kecil sesuai angka yang
// diisi, supaya bisa langsung "melihat" apakah tebakannya sudah pas bikin
// Pyto loncat 5 kali. Widget interaktif kecil (bukan animasi "sekali putar
// saat terlihat"), jadi memakai script sendiri seperti PyodideEditor,
// bukan observeOnce/wireReplay.
interface Props {
  target?: number;
}

const { target = 5 } = Astro.props;
---

<div class="pjg" data-target={target}>
  <div class="pjg__code">
    <span class="tok-p">for</span> i <span class="tok-p">in</span> <span class="tok-fn">range</span>(<span
      class="pjg__blank">___</span
    >):
    <br />
    &nbsp;&nbsp;&nbsp;&nbsp;<span class="tok-fn">print</span>(<span class="tok-str">&quot;Pyto loncat!&quot;</span>)
  </div>

  <div class="pjg__controls">
    <label class="pjg__label" for="pjg-input">
      Isi angkanya supaya Pyto loncat <strong>5 kali</strong>:
    </label>
    <div class="pjg__row">
      <input class="pjg__input" id="pjg-input" type="number" min="1" max="10" placeholder="?" />
      <button class="btn btn-primary pjg__btn" type="button">Cek! 🐍</button>
    </div>
  </div>

  <div class="pjg__stage">
    <span class="pjg__pyto" aria-hidden="true">🐍</span>
    <span class="pjg__feedback" aria-live="polite"></span>
  </div>
</div>

<style>
  .pjg {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .pjg__code {
    background: var(--code-bg);
    border-radius: var(--radius-code);
    padding: 14px 16px;
    font-family: var(--font-code);
    font-size: 14px;
    line-height: 1.85;
    color: var(--code-text);
    overflow-x: auto;
  }

  .tok-p {
    color: var(--code-purple);
  }

  .tok-fn {
    color: var(--code-blue);
  }

  .tok-str {
    color: var(--code-green);
  }

  .pjg__blank {
    display: inline-block;
    min-width: 24px;
    text-align: center;
    border-bottom: 2px dashed var(--sunny-yellow);
    color: var(--sunny-yellow);
    font-weight: 700;
  }

  .pjg__label {
    display: block;
    font-weight: 700;
    color: var(--ink);
  }

  .pjg__row {
    display: flex;
    gap: 10px;
    margin-top: 8px;
    flex-wrap: wrap;
  }

  .pjg__input {
    width: 80px;
    padding: 10px 14px;
    border-radius: var(--radius-btn);
    border: 2px solid var(--border);
    font-family: var(--font-code);
    font-size: 16px;
    text-align: center;
  }

  .pjg__input:focus {
    outline: none;
    border-color: var(--pyto-green);
  }

  .pjg__btn {
    padding: 10px 20px;
  }

  .pjg__stage {
    display: flex;
    align-items: center;
    gap: 14px;
    min-height: 40px;
  }

  .pjg__pyto {
    font-size: 30px;
    display: inline-block;
  }

  .pjg__pyto.is-jumping {
    animation: pjg-jump 0.26s ease-in-out;
  }

  @keyframes pjg-jump {
    0%,
    100% {
      transform: translateY(0);
    }
    45% {
      transform: translateY(-16px);
    }
  }

  .pjg__feedback {
    font-weight: 700;
    font-size: 14px;
  }

  .pjg__feedback--ok {
    color: var(--pyto-green-dark);
  }

  .pjg__feedback--no {
    color: var(--coral);
  }

  @media (prefers-reduced-motion: reduce) {
    .pjg__pyto.is-jumping {
      animation: none;
    }
  }
</style>

<script>
  document.querySelectorAll('.pjg').forEach((widget) => {
    const target = Number(widget.dataset.target) || 5;
    const input = widget.querySelector('.pjg__input');
    const button = widget.querySelector('.pjg__btn');
    const pyto = widget.querySelector('.pjg__pyto');
    const feedback = widget.querySelector('.pjg__feedback');

    if (!input || !button || !pyto || !feedback) return;

    let running = false;

    const jumpOnce = (onDone) => {
      pyto.classList.remove('is-jumping');
      void pyto.offsetWidth;
      pyto.classList.add('is-jumping');
      setTimeout(() => {
        pyto.classList.remove('is-jumping');
        onDone();
      }, 260);
    };

    const runJumps = (count) => {
      running = true;
      button.disabled = true;
      let done = 0;
      const step = () => {
        done += 1;
        jumpOnce(() => {
          if (done < count) {
            setTimeout(step, 90);
          } else {
            running = false;
            button.disabled = false;
          }
        });
      };
      step();
    };

    button.addEventListener('click', () => {
      if (running) return;
      const raw = Number(input.value);
      const count = Number.isFinite(raw) && raw > 0 ? Math.min(Math.round(raw), 10) : 0;

      feedback.classList.remove('pjg__feedback--ok', 'pjg__feedback--no');

      if (count === 0) {
        feedback.textContent = 'Isi dulu angkanya, ya!';
        feedback.classList.add('pjg__feedback--no');
        return;
      }

      runJumps(count);

      if (count === target) {
        feedback.textContent = `Tepat! Pyto loncat ${target} kali 🎉`;
        feedback.classList.add('pjg__feedback--ok');
      } else {
        feedback.textContent = `Pyto baru loncat ${count} kali. Supaya ${target} kali, isi range(${target}).`;
        feedback.classList.add('pjg__feedback--no');
      }
    });
  });
</script>
