---
// Latihan pertama pembaca ("Coba Sendiri Yuk"). Alih-alih ilustrasi statis
// seperti di desain, ini editor Pyodide SUNGGUHAN (memakai logika yang sama
// dengan EditorSection.astro di beranda) — supaya latihan pertama pembaca
// benar-benar jalan, bukan pura-pura. Konfeti #8 baru meletus sekali, saat
// kode yang mereka jalankan betul-betul mencetak sesuatu ke layar.
const starterCode = `print("Namaku adalah ...")
print("Aku berumur ... tahun")
print("Dan aku sedang belajar Python!")
`;
---

<div class="practice-wrap">
  <div class="practice card">
    <div class="practice__header">
      <span class="practice__title">🐍 Editor Python</span>
      <div class="practice__buttons">
        <button type="button" class="btn btn-secondary practice__reset" id="practice-reset">
          ↺ Reset
        </button>
        <button type="button" class="btn btn-primary practice__run" id="practice-run">
          ▶ Jalankan
        </button>
      </div>
    </div>

    <textarea
      id="practice-code"
      class="practice__code"
      spellcheck="false"
      autocomplete="off"
      autocapitalize="off"
      rows="4"
      aria-label="Kotak kode latihan pertama">{starterCode}</textarea
    >

    <div class="practice__result" id="practice-result">
      <span class="practice__result-label" id="practice-result-label">Hasil:</span>
      <pre class="practice__result-body" id="practice-result-body">Klik ▶ Jalankan untuk melihat hasilnya di sini.</pre>
    </div>
  </div>

  <div class="practice__confetti" id="practice-confetti" aria-hidden="true"></div>
</div>

<p class="practice__note">
  Ganti bagian titik-titik dengan namamu dan umurmu, lalu klik <strong>▶ Jalankan</strong>. Kalau
  tulisanmu muncul di layar — <strong>selamat, kamu baru saja ngoding untuk pertama kali!</strong> 🎉
</p>

<style>
  .practice-wrap {
    position: relative;
  }

  .practice {
    overflow: hidden;
  }

  .practice__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    flex-wrap: wrap;
    padding: 16px 20px;
    background: var(--cloud);
    border-bottom: 1px solid var(--border);
  }

  .practice__title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 16px;
  }

  .practice__buttons {
    display: flex;
    gap: 10px;
  }

  .practice__buttons .btn {
    padding: 10px 18px;
    font-size: 14px;
    min-height: 40px;
  }

  .practice__code {
    display: block;
    width: 100%;
    min-height: 120px;
    resize: vertical;
    border: none;
    outline: none;
    background: var(--code-bg);
    color: var(--code-text);
    font-family: var(--font-code);
    font-size: 15px;
    line-height: 1.7;
    padding: 20px;
    tab-size: 4;
  }

  .practice__result {
    padding: 18px 20px 22px;
    background: var(--white);
    transition: background-color 0.2s ease;
  }

  .practice__result.is-error {
    background: var(--box-awas-bg);
  }

  .practice__result-label {
    display: block;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 14px;
    color: var(--slate);
    margin-bottom: 8px;
  }

  .practice__result.is-error .practice__result-label {
    color: var(--coral);
  }

  .practice__result-body {
    margin: 0;
    font-family: var(--font-code);
    font-size: 15px;
    white-space: pre-wrap;
    word-break: break-word;
    color: var(--ink);
  }

  .practice__result.is-error .practice__result-body {
    color: #b3392f;
  }

  .practice__run:disabled,
  .practice__reset:disabled {
    opacity: 0.6;
    cursor: wait;
    transform: none;
  }

  .practice__confetti {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    z-index: 2;
  }

  .practice__note {
    margin-top: 16px;
    color: var(--slate);
  }

  @media (max-width: 600px) {
    .practice__header {
      justify-content: center;
      text-align: center;
    }

    .practice__code {
      font-size: 14px;
    }
  }
</style>

<script>
  import { LOADING_MESSAGE, isFirstPyodideLoad, runPython, friendlyError } from '../scripts/pyodide-runner.js';
  import { launchConfetti } from '../scripts/confetti.js';

  const codeEl = document.getElementById('practice-code');
  const runBtn = document.getElementById('practice-run');
  const resetBtn = document.getElementById('practice-reset');
  const resultWrap = document.getElementById('practice-result');
  const resultLabel = document.getElementById('practice-result-label');
  const resultBody = document.getElementById('practice-result-body');
  const confettiEl = document.getElementById('practice-confetti');

  const STARTER_CODE = codeEl ? codeEl.value : '';
  let confettiFired = false;

  function showResult(text, isError) {
    if (!resultWrap || !resultBody || !resultLabel) return;
    resultWrap.classList.toggle('is-error', isError);
    resultLabel.textContent = isError ? '⚠️ Oops! Ada yang perlu diperbaiki:' : 'Hasil:';
    resultBody.textContent = text || '(Tidak ada tulisan yang ditampilkan)';
  }

  runBtn?.addEventListener('click', async () => {
    if (!codeEl || !runBtn) return;
    const code = codeEl.value;

    runBtn.disabled = true;
    if (isFirstPyodideLoad()) {
      showResult(LOADING_MESSAGE, false);
    } else {
      showResult('Menjalankan...', false);
    }

    try {
      const output = await runPython(code);
      showResult(output, false);

      if (!confettiFired && output.trim().length > 0) {
        confettiFired = true;
        launchConfetti(confettiEl);
      }
    } catch (err) {
      showResult(friendlyError(err), true);
    } finally {
      runBtn.disabled = false;
    }
  });

  resetBtn?.addEventListener('click', () => {
    if (!codeEl) return;
    codeEl.value = STARTER_CODE;
    showResult('Klik ▶ Jalankan untuk melihat hasilnya di sini.', false);
  });
</script>
