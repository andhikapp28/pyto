---
// Animasi #4 (plan/bab-13-animasi.md): foto polaroid "disapu" gelombang
// abu-abu dari kiri ke kanan, warnanya luruh mengikuti sapuan sampai
// seluruh foto jadi hitam-putih. Sekali jalan saat terlihat, boleh diulang
// lewat hover/klik/fokus.
---

<div
  class="gsd-demo"
  data-anim="gsd-demo"
  tabindex="0"
  role="button"
  aria-label="Ulangi animasi mengubah foto jadi hitam-putih"
>
  <div class="gsd-demo__code">
    <div class="gsd-demo__line"><span class="tok-p">from</span> PIL <span class="tok-p">import</span> ImageOps</div>
    <div class="gsd-demo__line">&nbsp;</div>
    <div class="gsd-demo__line">
      <span class="tok-var">foto_hitam_putih</span> = ImageOps.<span class="gsd-demo__glow tok-fn"
        >grayscale</span
      >(foto)
    </div>
  </div>

  <div class="gsd-demo__stage">
    <div class="gsd-demo__polaroid">
      <span class="gsd-demo__photo" aria-hidden="true">
        <span class="gsd-demo__sun"></span>
        <span class="gsd-demo__mountain"></span>
        <span class="gsd-demo__wipe"></span>
      </span>
      <span class="gsd-demo__caption">foto_hitam_putih</span>
    </div>
  </div>
</div>

<p class="gsd-demo__hint">
  💡 Satu baris saja — Pillow yang mengurus semua perhitungan warnanya.
  <em>(Klik / hover untuk ulangi.)</em>
</p>

<style>
  .gsd-demo {
    display: flex;
    flex-direction: column;
    gap: 18px;
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-soft);
    padding: 22px 24px;
    cursor: pointer;
  }

  .gsd-demo__code {
    background: var(--code-bg);
    border-radius: var(--radius-code);
    padding: 16px 18px;
    font-family: var(--font-code);
    font-size: 13px;
    line-height: 1.85;
    color: var(--code-text);
    overflow-x: auto;
  }

  .gsd-demo__line {
    white-space: pre;
  }

  .tok-p {
    color: var(--code-purple);
  }

  .tok-var {
    color: var(--code-red);
  }

  .tok-fn {
    color: var(--code-blue);
  }

  .gsd-demo__glow {
    border-radius: 4px;
  }

  .gsd-demo.is-in .gsd-demo__glow {
    animation: gsd-demo-glow 0.6s ease 0.1s;
  }

  @keyframes gsd-demo-glow {
    0%,
    100% {
      background: transparent;
    }
    40% {
      background: rgba(97, 175, 239, 0.28);
    }
  }

  .gsd-demo__stage {
    display: flex;
    justify-content: center;
  }

  .gsd-demo__polaroid {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 8px 8px 10px;
    box-shadow: var(--shadow-soft);
  }

  .gsd-demo__photo {
    position: relative;
    display: block;
    width: 120px;
    height: 90px;
    overflow: hidden;
    border-radius: 4px;
    background: linear-gradient(180deg, var(--sky-blue) 0%, #cfe9ff 100%);
  }

  .gsd-demo__sun {
    position: absolute;
    top: 8px;
    right: 10px;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--sunny-yellow);
  }

  .gsd-demo__mountain {
    position: absolute;
    bottom: -8px;
    left: 0;
    width: 0;
    height: 0;
    border-left: 34px solid transparent;
    border-right: 34px solid transparent;
    border-bottom: 34px solid var(--pyto-green-dark);
  }

  .gsd-demo__wipe {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, #cfcfcf 0%, #8f8f8f 100%);
    clip-path: inset(0 100% 0 0);
  }

  .gsd-demo.is-in .gsd-demo__wipe {
    animation: gsd-demo-wipe 1.2s ease 0.6s forwards;
  }

  @keyframes gsd-demo-wipe {
    to {
      clip-path: inset(0 0 0 0);
    }
  }

  .gsd-demo__caption {
    font-family: var(--font-code);
    font-size: 11px;
    font-weight: 700;
    color: var(--slate);
  }

  .gsd-demo__hint {
    font-size: 14px;
    line-height: 1.55;
    margin: 0 2px;
    color: var(--slate);
  }

  @media (prefers-reduced-motion: reduce) {
    .gsd-demo__glow,
    .gsd-demo__wipe {
      animation: none !important;
    }

    .gsd-demo__wipe {
      clip-path: inset(0 0 0 0);
    }
  }
</style>

<script>
  import { observeOnce, wireReplay } from '../scripts/reveal-anim.js';

  const els = document.querySelectorAll('[data-anim="gsd-demo"]');

  observeOnce(els, (el) => {
    el.classList.add('is-in');
  });

  els.forEach((el) => wireReplay(el, 'is-in'));
</script>
