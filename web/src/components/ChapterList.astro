---
import { chapters, isChapterAvailable, AVAILABLE_CHAPTERS } from '../data/chapters.js';

// Deskripsi singkat tiap bab untuk kartu di beranda. Judul & ketersediaan
// datang dari data/chapters.js (sumber tunggal, dipakai juga oleh sidebar
// ChapterLayout.astro) — di sini cuma nambah kalimat singkat per bab.
const descriptions = {
  1: 'Apa itu ngoding, dan kenapa Python seru untuk dipelajari.',
  2: 'Perintah print() dan cara komputer "berbicara".',
  3: 'Mengenal variabel, kotak ajaib penyimpan informasi.',
  4: 'Perintah input() untuk membuat program interaktif.',
  5: 'Menjadikan Python sebagai kalkulator super.',
  6: 'if dan else, cara komputer mengambil keputusan.',
  7: 'for dan while, menyuruh komputer mengulang tanpa capek.',
  8: 'Daftar teman, daftar belanja — kumpulan data dalam satu kotak.',
  9: 'Cara membaca pesan error tanpa panik, lalu memperbaikinya.',
  10: '3 mini-project seru: Tebak Angka, Kuis, dan Kalkulator.',
};

const totalChapters = chapters.length;
const availableCount = AVAILABLE_CHAPTERS.length;
---

<section class="chapters" id="bab">
  <div class="container">
    <div class="section-head">
      <h2>Mulai Petualanganmu</h2>
      <p>
        {totalChapters} bab dari nol sampai bisa, {availableCount} bab pertama sudah bisa dicoba
        sekarang. Satu konsep tiap bab, pelan-pelan saja.
      </p>
    </div>

    <ol class="chapters__list">
      {
        chapters.map((chapter) => {
          const available = isChapterAvailable(chapter.number);
          const Tag = available ? 'a' : 'div';
          return (
            <li>
              <Tag
                id={available ? `bab-${chapter.number}` : undefined}
                href={available ? `${import.meta.env.BASE_URL}/bab/${chapter.number}/` : undefined}
                class={`chapter-card ${available ? 'chapter-card--active' : ''}`}
                data-reveal
              >
                <span class="chapter-card__number">{chapter.number}</span>
                <span class="chapter-card__body">
                  <span class="chapter-card__title">{chapter.title}</span>
                  <span class="chapter-card__desc">{descriptions[chapter.number]}</span>
                </span>
                <span class="chapter-card__tag">
                  {available ? 'Mulai di sini →' : 'Segera'}
                </span>
              </Tag>
            </li>
          );
        })
      }
    </ol>
  </div>
</section>

<style>
  .chapters {
    background: var(--cloud);
    padding-block: var(--section-spacing);
  }

  .chapters__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 16px;
    max-width: 780px;
    margin-inline: auto;
  }

  .chapter-card {
    display: flex;
    align-items: center;
    gap: 20px;
    padding: 22px 24px;
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-soft);
    text-decoration: none;
    color: inherit;
    transition: transform 0.25s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.25s ease;
  }

  a.chapter-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 24px rgba(30, 42, 50, 0.1);
  }

  .chapter-card--active {
    background: var(--pyto-green-soft);
    border-color: var(--pyto-green);
  }

  .chapter-card__number {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    border-radius: 999px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 18px;
    background: var(--cloud);
    color: var(--slate);
  }

  .chapter-card--active .chapter-card__number {
    background: var(--pyto-green);
    color: var(--white);
  }

  .chapter-card__body {
    display: flex;
    flex-direction: column;
    gap: 4px;
    flex: 1;
    min-width: 0;
  }

  .chapter-card__title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 18px;
  }

  .chapter-card__desc {
    color: var(--slate);
    font-size: 15px;
  }

  .chapter-card__tag {
    flex-shrink: 0;
    font-size: 14px;
    font-weight: 700;
    padding: 8px 14px;
    border-radius: 999px;
    background: var(--cloud);
    color: var(--slate);
    white-space: nowrap;
  }

  .chapter-card--active .chapter-card__tag {
    background: var(--pyto-green);
    color: var(--white);
  }

  @media (max-width: 600px) {
    .chapter-card {
      flex-direction: column;
      align-items: flex-start;
      gap: 10px;
      padding: 18px;
    }

    .chapter-card__desc {
      max-width: none;
    }
  }
</style>
