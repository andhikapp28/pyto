---
// Animasi #5 (plan/bab-03-animasi.md) — momen utama Bab 3: isi kotak
// berganti. Bola lama (10) terdorong keluar dan memudar, bola baru (11)
// jatuh masuk menggantikannya di posisi yang sama; label kotak (nama
// variabel) tidak berubah. Main sekali saat terlihat, dan boleh diulang
// dengan hover/klik pada kartu (sesuai spek: "Boleh diulang sekali kalau
// pembaca meng-klik/hover contoh ini").
interface Props {
  varName?: string;
  oldValue?: string;
  newValue?: string;
}

const { varName = 'umur', oldValue = '10', newValue = '11' } = Astro.props;
---

<div class="reassign" data-anim="reassign" tabindex="0" role="button" aria-label="Ulangi animasi penggantian isi kotak">
  <div class="reassign__code card">
    <pre class="reassign__pre"><code
      ><span class="reassign__line"><span class="tok-var">{varName}</span> <span class="tok-eq">=</span> <span class="tok-val">{oldValue}</span></span
      ><span class="reassign__line"><span class="tok-fn">print</span>(<span class="tok-var">{varName}</span>)  <span class="tok-comment"># {oldValue}</span></span
      ><span class="reassign__line reassign__spacer">&nbsp;</span
      ><span class="reassign__line reassign__line2"><span class="tok-var">{varName}</span> <span class="tok-eq">=</span> <span class="tok-val">{newValue}</span></span
      ><span class="reassign__line"><span class="tok-fn">print</span>(<span class="tok-var">{varName}</span>)  <span class="tok-comment"># {newValue}</span></span
    ></code></pre>
    </div>

  <div class="reassign__col">
    <div class="reassign__box">
      <div class="reassign__rim"></div>
      <div class="reassign__band"></div>
      <span class="reassign__ball reassign__ball--old" aria-hidden="true">{oldValue}</span>
      <span class="reassign__ball reassign__ball--new" aria-hidden="true">{newValue}</span>
      <span class="reassign__label" aria-hidden="true">{varName}</span>
    </div>
    <p class="reassign__caption">{oldValue} keluar → {newValue} masuk</p>
  </div>
</div>

<style>
  .reassign {
    position: relative;
    display: flex;
    gap: 24px;
    align-items: center;
    flex-wrap: wrap;
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-soft);
    padding: 22px 24px;
    cursor: pointer;
  }

  .reassign__code {
    flex: 1;
    min-width: 240px;
    background: var(--code-bg);
    border-radius: var(--radius-code);
    padding: 16px 18px;
    overflow-x: auto;
  }

  .reassign__pre {
    margin: 0;
    font-family: var(--font-code);
    font-size: 16px;
    line-height: 1.95;
    color: var(--code-text);
  }

  .reassign__line {
    display: block;
  }

  .reassign__spacer {
    height: 10px;
  }

  .reassign__line2 {
    border-radius: 4px;
  }

  .tok-var {
    color: var(--code-red);
  }

  .tok-eq {
    color: var(--code-text);
  }

  .tok-val {
    color: var(--code-orange);
  }

  .tok-fn {
    color: var(--code-blue);
  }

  .tok-comment {
    color: var(--code-comment);
  }

  /* ---- kolom kotak ---- */
  .reassign__col {
    position: relative;
    width: 130px;
    flex-shrink: 0;
    text-align: center;
  }

  .reassign__box {
    position: relative;
    width: 118px;
    height: 100px;
    margin: 0 auto;
  }

  .reassign__rim {
    position: absolute;
    bottom: 0;
    width: 118px;
    height: 78px;
    border-radius: 10px;
    background: linear-gradient(var(--wood), var(--wood-dark));
    border: 3px solid var(--wood-border);
    box-shadow: 0 6px 14px rgba(154, 99, 41, 0.28);
    z-index: 2;
  }

  .reassign__band {
    position: absolute;
    top: 0;
    left: 9px;
    width: 100px;
    height: 14px;
    border-radius: 8px;
    background: var(--wood-label-text);
    z-index: 2;
  }

  .reassign__ball {
    position: absolute;
    left: 50%;
    top: -4px;
    transform: translateX(-50%);
    z-index: 3;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-code);
    font-weight: 700;
    font-size: 18px;
  }

  .reassign__ball--old {
    background: radial-gradient(circle at 34% 30%, #f0b57e, var(--code-orange));
    border: 2px solid #b77b44;
    color: #5a3a16;
    box-shadow: 0 4px 8px rgba(183, 123, 68, 0.4);
    opacity: 1;
  }

  .reassign__ball--new {
    background: radial-gradient(circle at 34% 30%, #8fe0ae, var(--pyto-green));
    border: 2px solid var(--pyto-green-dark);
    color: #0e3d22;
    box-shadow: 0 4px 8px rgba(47, 191, 113, 0.5);
    opacity: 0;
  }

  .reassign__label {
    position: absolute;
    bottom: 14px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 4;
    background: var(--box-main-yuk-bg);
    border: 2px solid var(--wood-label-border);
    color: var(--wood-label-text);
    font-family: var(--font-code);
    font-weight: 700;
    font-size: 14px;
    padding: 3px 12px;
    border-radius: 7px;
    box-shadow: 0 2px 5px rgba(0, 0, 0, 0.12);
  }

  .reassign__caption {
    font-size: 13px;
    color: var(--slate);
    margin: 10px 0 0;
    font-weight: 600;
  }

  /* ---- animasi ---- */
  .reassign.is-in .reassign__ball--old {
    animation: reassign-ball-out 0.6s cubic-bezier(0.5, 0, 0.7, 0.3) 0.2s forwards;
  }

  .reassign.is-in .reassign__ball--new {
    animation: reassign-ball-in 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) 1s forwards;
  }

  .reassign.is-in .reassign__line2 {
    animation: reassign-glow-yellow 0.6s ease 0s 1;
  }

  .reassign.is-in .reassign__rim {
    animation: reassign-box-flash 0.7s ease 1.1s 1;
  }

  @keyframes reassign-ball-out {
    0% {
      opacity: 1;
      transform: translate(-50%, 0) scale(1);
    }
    100% {
      opacity: 0;
      transform: translate(-50%, -46px) scale(0.7) rotate(18deg);
    }
  }

  @keyframes reassign-ball-in {
    0% {
      opacity: 0;
      transform: translate(-50%, -40px) scale(0.6);
    }
    55% {
      opacity: 1;
    }
    70% {
      transform: translate(-50%, 4px) scale(1);
    }
    85% {
      transform: translate(-50%, -4px) scale(1);
    }
    100% {
      opacity: 1;
      transform: translate(-50%, 0) scale(1);
    }
  }

  @keyframes reassign-glow-yellow {
    0%, 100% {
      background: transparent;
    }
    30% {
      background: rgba(255, 201, 77, 0.4);
    }
  }

  @keyframes reassign-box-flash {
    0%, 100% {
      box-shadow: 0 6px 14px rgba(154, 99, 41, 0.28);
    }
    45% {
      box-shadow: 0 0 0 5px rgba(47, 191, 113, 0.45), 0 6px 14px rgba(154, 99, 41, 0.28);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .reassign__ball--old,
    .reassign__ball--new,
    .reassign__line2,
    .reassign__rim {
      animation: none !important;
    }

    .reassign__ball--old {
      opacity: 0;
    }

    .reassign__ball--new {
      opacity: 1;
      transform: translateX(-50%);
    }
  }

  @media (max-width: 600px) {
    .reassign__pre {
      font-size: 14px;
    }
  }
</style>

<script>
  import { observeOnce } from '../scripts/reveal-anim.js';

  const els = document.querySelectorAll('[data-anim="reassign"]');

  observeOnce(els, (el) => {
    el.classList.add('is-in');
  });

  // Boleh diulang: hover/klik/fokus keyboard memutar ulang animasinya.
  els.forEach((el) => {
    const replay = () => {
      el.classList.remove('is-in');
      // eslint-disable-next-line no-unused-expressions
      void el.offsetWidth; // paksa reflow supaya animasi bisa diulang
      el.classList.add('is-in');
    };
    el.addEventListener('mouseenter', replay);
    el.addEventListener('click', replay);
    el.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        replay();
      }
    });
  });
</script>
