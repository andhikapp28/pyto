---
// Animasi #3 (plan/bab-08-animasi.md): belanja = ["Roti", "Susu"], lalu
// belanja.append("Telur") menyala, keping baru "Telur" melayang masuk dari
// kanan dan menyambung di ujung deretan (bukan menyisip di tengah), nomor
// urut baru (2) muncul otomatis. Sekali jalan saat terlihat, boleh diulang
// lewat hover/klik/fokus.
const before = ['Roti', 'Susu'];
---

<div
  class="apd-demo"
  data-anim="apd-demo"
  tabindex="0"
  role="button"
  aria-label="Ulangi animasi menambah barang ke daftar dengan append"
>
  <div class="apd-demo__code">
    <div class="apd-demo__line">
      <span class="tok-var">belanja</span> = [<span class="tok-str">&quot;Roti&quot;</span>,
      <span class="tok-str">&quot;Susu&quot;</span>]
    </div>
    <div class="apd-demo__line">
      <span class="apd-demo__glow">belanja.<span class="tok-fn">append</span>(<span class="tok-str"
          >&quot;Telur&quot;</span
        >)</span
      >
    </div>
    <div class="apd-demo__line">&nbsp;</div>
    <div class="apd-demo__line"><span class="tok-fn">print</span>(belanja)</div>
  </div>

  <div class="apd-demo__stage">
    <span class="apd-demo__label">belanja</span>
    <div class="apd-demo__cars">
      {
        before.map((label, i) => (
          <div class="apd-demo__col">
            <span class="apd-demo__car">{label}</span>
            <span class="apd-demo__index">{i}</span>
          </div>
        ))
      }
      <div class="apd-demo__col apd-demo__col--new">
        <span class="apd-demo__car apd-demo__car--new">Telur</span>
        <span class="apd-demo__index apd-demo__index--new">2</span>
      </div>
    </div>
  </div>
</div>

<p class="apd-demo__hint">
  💡 <code>.append(...)</code> selalu menambah barang baru <strong>di ujung akhir</strong> daftar —
  daftarnya otomatis memanjang. <em>(Klik / hover untuk ulangi.)</em>
</p>

<style>
  .apd-demo {
    display: flex;
    flex-direction: column;
    gap: 18px;
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-soft);
    padding: 22px 24px;
    cursor: pointer;
  }

  .apd-demo__code {
    background: var(--code-bg);
    border-radius: var(--radius-code);
    padding: 16px 18px;
    font-family: var(--font-code);
    font-size: 15px;
    line-height: 1.9;
    color: var(--code-text);
    overflow-x: auto;
  }

  .apd-demo__line {
    white-space: pre;
  }

  .tok-var {
    color: var(--code-red);
  }

  .tok-str {
    color: var(--code-green);
  }

  .tok-fn {
    color: var(--code-blue);
  }

  .apd-demo__glow {
    border-radius: 6px;
    padding: 1px 3px;
    margin: -1px -3px;
  }

  .apd-demo.is-in .apd-demo__glow {
    animation: apd-demo-glow 0.6s ease 0.1s;
  }

  @keyframes apd-demo-glow {
    0%,
    100% {
      background: transparent;
    }
    40% {
      background: rgba(97, 175, 239, 0.28);
    }
  }

  .apd-demo__stage {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }

  .apd-demo__label {
    font-family: var(--font-code);
    font-weight: 700;
    font-size: 13px;
    color: var(--slate);
  }

  .apd-demo__cars {
    display: flex;
    gap: 4px;
  }

  .apd-demo__col {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
  }

  .apd-demo__car {
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--code-green);
    color: #1e3a16;
    border: 2px solid #7bae58;
    border-radius: 8px;
    padding: 8px 12px;
    font-family: var(--font-code);
    font-weight: 700;
    font-size: 14px;
  }

  .apd-demo__index {
    font-family: var(--font-code);
    font-weight: 800;
    font-size: 13px;
    color: var(--slate);
    width: 22px;
    height: 22px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--cloud);
  }

  .apd-demo__col--new {
    opacity: 0;
    transform: translateX(40px);
  }

  .apd-demo.is-in .apd-demo__col--new {
    animation: apd-demo-slide-in 0.55s cubic-bezier(0.34, 1.56, 0.64, 1) 0.8s forwards;
  }

  .apd-demo.is-in .apd-demo__car--new {
    animation: apd-demo-jitter 0.3s ease 1.4s;
  }

  @keyframes apd-demo-slide-in {
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  @keyframes apd-demo-jitter {
    0%,
    100% {
      transform: translateX(0);
    }
    25% {
      transform: translateX(-2px);
    }
    75% {
      transform: translateX(2px);
    }
  }

  .apd-demo__index--new {
    opacity: 0;
  }

  .apd-demo.is-in .apd-demo__index--new {
    animation: apd-demo-fade-in 0.4s ease 1.6s forwards;
  }

  @keyframes apd-demo-fade-in {
    to {
      opacity: 1;
    }
  }

  .apd-demo__hint {
    font-size: 14px;
    line-height: 1.55;
    margin: 0 2px;
    color: var(--slate);
  }

  .apd-demo__hint code {
    color: var(--pyto-green-dark);
    font-weight: 700;
  }

  @media (prefers-reduced-motion: reduce) {
    .apd-demo__glow,
    .apd-demo__col--new,
    .apd-demo__car--new,
    .apd-demo__index--new {
      animation: none !important;
    }

    .apd-demo__col--new,
    .apd-demo__index--new {
      opacity: 1;
      transform: none;
    }
  }

  @media (max-width: 600px) {
    .apd-demo__code {
      font-size: 14px;
    }
  }
</style>

<script>
  import { observeOnce, wireReplay } from '../scripts/reveal-anim.js';

  const els = document.querySelectorAll('[data-anim="apd-demo"]');

  observeOnce(els, (el) => {
    el.classList.add('is-in');
  });

  els.forEach((el) => wireReplay(el, 'is-in'));
</script>
