---
// Animasi #2 (plan/bab-10-animasi.md): kotak alat "random" melayang masuk
// dan diselipkan ke rompi Pyto lewat import random, lalu
// random.randint(1, 20) didemonstrasikan lewat dadu digital yang berputar
// cepat menampilkan angka berganti-ganti lalu melambat dan berhenti di satu
// bola angka acak, yang jatuh ke kotak angka_rahasia. Sekali jalan saat
// terlihat, boleh diulang lewat hover/klik/fokus.
const spins = [7, 14, 2, 19, 11];
const finalValue = 8;
---

<div
  class="rdd-demo"
  data-anim="rdd-demo"
  tabindex="0"
  role="button"
  aria-label="Ulangi animasi import random dan random.randint"
>
  <div class="rdd-demo__code">
    <div class="rdd-demo__line rdd-demo__import">
      <span class="tok-p">import</span> random
    </div>
    <div class="rdd-demo__line">&nbsp;</div>
    <div class="rdd-demo__line">
      <span class="tok-var">angka_rahasia</span> = random.<span class="tok-fn">randint</span>(<span
        class="tok-num">1</span
      >, <span class="tok-num">20</span>)
    </div>
    <div class="rdd-demo__line"><span class="tok-fn">print</span>(angka_rahasia)</div>
  </div>

  <p class="rdd-demo__note">
    💬 <code>random</code> itu kotak alat siap pakai buatan Python, isinya macam-macam cara bikin
    sesuatu jadi acak.
  </p>

  <div class="rdd-demo__stage">
    <div class="rdd-demo__dice">
      <span class="rdd-demo__dice-icon" aria-hidden="true">🎲</span>
      <div class="rdd-demo__numbers">
        {
          spins.map((n, i) => (
            <span class="rdd-demo__num" style={`animation-delay:${i * 0.12}s`}>
              {n}
            </span>
          ))
        }
        <span class="rdd-demo__num rdd-demo__num--final">{finalValue}</span>
      </div>
    </div>

    <span class="rdd-demo__arrow" aria-hidden="true">↓</span>

    <div class="rdd-demo__box">
      <span class="rdd-demo__box-label">angka_rahasia</span>
      <span class="rdd-demo__box-value">{finalValue}</span>
    </div>
  </div>
</div>

<style>
  .rdd-demo {
    display: flex;
    flex-direction: column;
    gap: 14px;
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-soft);
    padding: 22px 24px;
    cursor: pointer;
  }

  .rdd-demo__code {
    background: var(--code-bg);
    border-radius: var(--radius-code);
    padding: 14px 16px;
    font-family: var(--font-code);
    font-size: 14px;
    line-height: 1.85;
    color: var(--code-text);
    overflow-x: auto;
  }

  .rdd-demo__line {
    white-space: pre;
  }

  .tok-p {
    color: var(--code-purple);
  }

  .tok-var {
    color: var(--code-red);
  }

  .tok-fn {
    color: var(--code-blue);
  }

  .tok-num {
    color: var(--code-orange);
  }

  .rdd-demo__import {
    border-radius: 6px;
  }

  .rdd-demo.is-in .rdd-demo__import {
    animation: rdd-demo-import-glow 0.7s ease 0.1s;
  }

  @keyframes rdd-demo-import-glow {
    0%,
    100% {
      background: transparent;
    }
    40% {
      background: rgba(139, 111, 224, 0.28);
    }
  }

  .rdd-demo__note {
    margin: 0;
    font-size: 14px;
    color: var(--slate);
  }

  .rdd-demo__note code {
    color: var(--pyto-green-dark);
    font-weight: 700;
  }

  .rdd-demo__stage {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }

  .rdd-demo__dice {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 64px;
    height: 64px;
  }

  .rdd-demo__dice-icon {
    font-size: 36px;
    opacity: 0.25;
  }

  .rdd-demo__numbers {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .rdd-demo__num {
    position: absolute;
    font-family: var(--font-code);
    font-weight: 800;
    font-size: 22px;
    color: var(--grape);
    opacity: 0;
  }

  .rdd-demo.is-in .rdd-demo__num {
    animation: rdd-demo-num-flash 0.12s steps(1) forwards;
  }

  @keyframes rdd-demo-num-flash {
    0% {
      opacity: 1;
    }
    99% {
      opacity: 1;
    }
    100% {
      opacity: 0;
    }
  }

  .rdd-demo__num--final {
    color: var(--pyto-green-dark);
  }

  .rdd-demo.is-in .rdd-demo__num--final {
    animation: rdd-demo-final-in 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) 0.7s forwards;
  }

  @keyframes rdd-demo-final-in {
    0% {
      opacity: 0;
      transform: scale(0.6);
    }
    60% {
      opacity: 1;
      transform: scale(1.3);
    }
    100% {
      opacity: 1;
      transform: scale(1);
    }
  }

  .rdd-demo__arrow {
    color: var(--border);
    font-size: 16px;
  }

  .rdd-demo__box {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    background: var(--box-main-yuk-bg);
    border: 2px solid var(--wood-label-border);
    border-radius: 12px;
    padding: 8px 18px;
    opacity: 0;
    transform: translateY(-8px);
  }

  .rdd-demo.is-in .rdd-demo__box {
    animation: rdd-demo-box-in 0.4s ease 1.1s forwards;
  }

  @keyframes rdd-demo-box-in {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .rdd-demo__box-label {
    font-family: var(--font-code);
    font-weight: 700;
    font-size: 11px;
    color: var(--wood-label-text);
  }

  .rdd-demo__box-value {
    font-family: var(--font-code);
    font-weight: 800;
    font-size: 20px;
    color: var(--wood-label-text);
  }

  @media (prefers-reduced-motion: reduce) {
    .rdd-demo__import,
    .rdd-demo__num,
    .rdd-demo__num--final,
    .rdd-demo__box {
      animation: none !important;
    }

    .rdd-demo__num {
      opacity: 0;
    }

    .rdd-demo__num--final,
    .rdd-demo__box {
      opacity: 1;
      transform: none;
    }
  }

  @media (max-width: 600px) {
    .rdd-demo__code {
      font-size: 13px;
    }
  }
</style>

<script>
  import { observeOnce, wireReplay } from '../scripts/reveal-anim.js';

  const els = document.querySelectorAll('[data-anim="rdd-demo"]');

  observeOnce(els, (el) => {
    el.classList.add('is-in');
  });

  els.forEach((el) => wireReplay(el, 'is-in'));
</script>
