---
// Animasi #8 (plan/bab-03-animasi.md): aturan penamaan variabel. `2nama`
// "ditolak" (goyang + dicoret), `nama2` "diterima" (centang muncul), lalu
// `Nama` vs `nama` ditampilkan sebagai dua kotak terpisah untuk menandakan
// Python membedakan huruf besar/kecil. Sekali jalan saat terlihat.
---

<div class="naming" data-anim="naming">
  <div class="naming__grid">
    <div class="naming__card">
      <div class="naming__card-title">Boleh vs Tidak Boleh</div>
      <div class="naming__rows">
        <div class="naming__row">
          <span class="naming__bad" aria-hidden="true">
            2nama
            <span class="naming__strike"></span>
          </span>
          <span class="naming__cross" aria-hidden="true">✗</span>
          <span class="naming__sr">2nama tidak boleh, diawali angka.</span>
        </div>
        <div class="naming__row">
          <span class="naming__good" aria-hidden="true">nama2</span>
          <span class="naming__check" aria-hidden="true">✓</span>
          <span class="naming__sr">nama2 boleh.</span>
        </div>
      </div>
    </div>

    <div class="naming__card">
      <div class="naming__card-title">Besar/kecil = kotak berbeda</div>
      <div class="naming__compare">
        <div class="naming__mini">
          <div class="naming__mini-box">
            <div class="naming__mini-rim"></div>
            <span class="naming__mini-label">Nama</span>
          </div>
        </div>
        <span class="naming__neq" aria-hidden="true">≠</span>
        <div class="naming__mini">
          <div class="naming__mini-box">
            <div class="naming__mini-rim"></div>
            <span class="naming__mini-label">nama</span>
          </div>
        </div>
      </div>
      <p class="naming__note">Python menganggap ini dua kotak berbeda!</p>
    </div>
  </div>
</div>

<style>
  .naming__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .naming__card {
    background: var(--white);
    border: 1px solid #d6e5f5;
    border-radius: 12px;
    padding: 16px 18px;
  }

  .naming__card-title {
    font-size: 13px;
    font-weight: 800;
    color: #2a78c2;
    margin-bottom: 12px;
  }

  .naming__rows {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .naming__row {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .naming__sr {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
  }

  .naming__bad {
    position: relative;
    display: inline-block;
    font-family: var(--font-code);
    font-weight: 700;
    font-size: 16px;
    color: #c0392b;
    background: #fbe3e0;
    border: 2px solid #e8a9a2;
    border-radius: 7px;
    padding: 4px 12px;
  }

  .naming__strike {
    position: absolute;
    left: 6px;
    top: 50%;
    height: 2px;
    width: 0;
    background: #c0392b;
  }

  .naming__cross {
    color: #c0392b;
    font-size: 20px;
  }

  .naming__good {
    font-family: var(--font-code);
    font-weight: 700;
    font-size: 16px;
    color: var(--pyto-green-dark);
    background: var(--pyto-green-soft);
    border: 2px solid #a9dec0;
    border-radius: 7px;
    padding: 4px 12px;
  }

  .naming__check {
    color: var(--pyto-green-dark);
    font-size: 20px;
    display: inline-block;
    transform: scale(0);
  }

  .naming__compare {
    display: flex;
    gap: 14px;
    align-items: flex-end;
  }

  .naming__mini-box {
    position: relative;
    width: 72px;
    height: 58px;
  }

  .naming__mini-rim {
    position: absolute;
    bottom: 0;
    width: 72px;
    height: 46px;
    border-radius: 8px;
    background: linear-gradient(var(--wood), var(--wood-dark));
    border: 2px solid var(--wood-border);
  }

  .naming__mini-label {
    position: absolute;
    bottom: 9px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--box-main-yuk-bg);
    border: 2px solid var(--wood-label-border);
    color: var(--wood-label-text);
    font-family: var(--font-code);
    font-weight: 700;
    font-size: 12px;
    padding: 1px 8px;
    border-radius: 5px;
  }

  .naming__neq {
    color: var(--slate);
    font-weight: 800;
    font-size: 18px;
    padding-bottom: 18px;
  }

  .naming__note {
    font-size: 13px;
    line-height: 1.5;
    color: var(--slate);
    margin: 12px 0 0;
  }

  /* ---- animasi ---- */
  .naming.is-in .naming__bad {
    animation: naming-reject-shake 0.6s ease 0.3s 1;
  }

  .naming.is-in .naming__strike {
    animation: naming-strike-in 0.5s ease 0.5s forwards;
  }

  .naming.is-in .naming__check {
    animation: naming-check-pop 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) 0.7s forwards;
  }

  @keyframes naming-reject-shake {
    0%, 100% {
      transform: translateX(0);
    }
    20% {
      transform: translateX(-5px) rotate(-2deg);
    }
    40% {
      transform: translateX(5px) rotate(2deg);
    }
    60% {
      transform: translateX(-4px) rotate(-1deg);
    }
    80% {
      transform: translateX(3px);
    }
  }

  @keyframes naming-strike-in {
    from {
      width: 0;
    }
    to {
      width: calc(100% - 12px);
    }
  }

  @keyframes naming-check-pop {
    0% {
      transform: scale(0);
    }
    70% {
      transform: scale(1.3);
    }
    100% {
      transform: scale(1);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .naming__bad,
    .naming__strike,
    .naming__check {
      animation: none !important;
    }

    .naming__strike {
      width: calc(100% - 12px);
    }

    .naming__check {
      transform: scale(1);
    }
  }

  @media (max-width: 600px) {
    .naming__grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  import { observeOnce } from '../scripts/reveal-anim.js';

  observeOnce(document.querySelectorAll('[data-anim="naming"]'), (el) => {
    el.classList.add('is-in');
  });
</script>
