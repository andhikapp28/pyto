---
const features = [
  {
    icon: '🎮',
    title: 'Game',
    desc: 'Bikin permainan tebak angka sampai game seru sendiri.',
    bg: '#FFF6E0',
  },
  {
    icon: '📱',
    title: 'Aplikasi & Web',
    desc: 'Banyak aplikasi dan website dibuat pakai Python.',
    bg: '#EAF3FF',
  },
  {
    icon: '🤖',
    title: 'Robot & AI',
    desc: 'Perintah robot dan kecerdasan buatan.',
    bg: '#F2EDFD',
  },
  {
    icon: '🎬',
    title: 'Film & NASA',
    desc: 'Dipakai pembuat film animasi bahkan NASA!',
    bg: '#E4F7ED',
  },
];
---

<section class="features" id="fitur">
  <div class="container">
    <div class="section-head">
      <h2>Kenapa Python?</h2>
      <p>Satu bahasa pemrograman, sejuta kemungkinan. Ini baru sedikit contohnya.</p>
    </div>

    <div class="features__grid">
      {
        features.map((feature) => (
          <div class="feature-card card" data-reveal>
            <div class="feature-card__icon" style={`background:${feature.bg}`}>
              <span>{feature.icon}</span>
            </div>
            <h3>{feature.title}</h3>
            <p>{feature.desc}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .features {
    background: var(--cloud);
    padding-block: var(--section-spacing);
  }

  .features__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }

  .feature-card {
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .feature-card__icon {
    width: 56px;
    height: 56px;
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 28px;
  }

  .feature-card p {
    color: var(--slate);
    font-size: 16px;
  }

  @media (max-width: 960px) {
    .features__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 560px) {
    .features__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
