---
// Latihan interaktif Bab 5 ("Coba Sendiri: Kalkulator Sungguhan!") — memakai
// pola yang sama dengan InteractivePracticeEditor.astro (Bab 4):
// runPythonInteractive() dari pyodide-runner.js, sehingga dua input()
// berturut-turut di kode pembaca benar-benar SUNGGUHAN berhenti dan menunggu
// jawaban satu per satu lewat kotak isian di console, sebelum akhirnya
// menjumlahkan kedua angka. Konfeti (beat #9) meletus sekali, saat kode yang
// dijalankan pembaca betul-betul mencetak sesuatu.
const starterCode = `angka1 = input("Masukkan angka pertama: ")
angka2 = input("Masukkan angka kedua: ")

angka1 = int(angka1)
angka2 = int(angka2)

print("Hasil jumlahnya:", angka1 + angka2)
`;
---

<div class="cpe-wrap">
  <div class="cpe card">
    <div class="cpe__header">
      <span class="cpe__title">🐍 kalkulator.py</span>
      <div class="cpe__buttons">
        <button type="button" class="btn btn-secondary cpe__reset" id="cpe-reset"> ↺ Reset </button>
        <button type="button" class="btn btn-primary cpe__run" id="cpe-run"> ▶ Jalankan </button>
      </div>
    </div>

    <textarea
      id="cpe-code"
      class="cpe__code"
      spellcheck="false"
      autocomplete="off"
      autocapitalize="off"
      rows="6"
      aria-label="Kotak kode kalkulator">{starterCode}</textarea
    >

    <div class="cpe__console">
      <div class="cpe__console-label">Output:</div>
      <div class="cpe__console-body" id="cpe-console-body" aria-live="polite">
        <div class="cpe__placeholder" id="cpe-placeholder">Klik ▶ Jalankan untuk menjalankan kode di atas.</div>
      </div>
    </div>
  </div>

  <div class="cpe__confetti" id="cpe-confetti" aria-hidden="true"></div>
</div>

<p class="cpe__note">
  📌 Saat kode sampai di <code>input()</code>, akan muncul kotak isian kecil di console — isi lalu tekan
  Enter atau klik <strong>Kirim</strong>.
</p>
<p class="cpe__note">
  ✏️ Ganti <code>int()</code> jadi <code>float()</code> kalau mau coba angka desimal!
</p>

<style>
  .cpe-wrap {
    position: relative;
  }

  .cpe {
    overflow: hidden;
  }

  .cpe__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    flex-wrap: wrap;
    padding: 16px 20px;
    background: var(--cloud);
    border-bottom: 1px solid var(--border);
  }

  .cpe__title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 16px;
  }

  .cpe__buttons {
    display: flex;
    gap: 10px;
  }

  .cpe__buttons .btn {
    padding: 10px 18px;
    font-size: 14px;
    min-height: 40px;
  }

  .cpe__code {
    display: block;
    width: 100%;
    min-height: 150px;
    resize: vertical;
    border: none;
    outline: none;
    background: var(--code-bg);
    color: var(--code-text);
    font-family: var(--font-code);
    font-size: 15px;
    line-height: 1.7;
    padding: 20px;
    tab-size: 4;
  }

  .cpe__console {
    padding: 16px 20px 20px;
    background: var(--console-bg);
  }

  .cpe__console-label {
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.4px;
    text-transform: uppercase;
    color: var(--code-comment);
    margin-bottom: 8px;
  }

  .cpe__console-body {
    font-family: var(--font-code);
    font-size: 15px;
    color: var(--code-text);
    line-height: 1.9;
    min-height: 90px;
    max-height: 320px;
    overflow-y: auto;
  }

  .cpe__placeholder {
    color: var(--code-comment);
  }

  .cpe__console-body :global(.cpe__line) {
    margin: 2px 0;
    white-space: pre-wrap;
    word-break: break-word;
  }

  .cpe__console-body :global(.cpe__line--loading) {
    color: var(--sunny-yellow);
    font-weight: 700;
  }

  .cpe__console-body :global(.cpe__final) {
    margin-top: 4px;
    color: var(--code-green);
    font-weight: 800;
  }

  .cpe__console-body :global(.cpe__error) {
    margin: 4px 0;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--code-error-bg);
    border: 1px solid var(--code-error-border);
    border-radius: 8px;
    padding: 6px 12px;
    color: var(--code-error-text);
    font-weight: 700;
    font-size: 13px;
  }

  .cpe__console-body :global(.cpe__answer) {
    color: var(--code-green);
    font-weight: 700;
  }

  .cpe__console-body :global(.cpe__input-row) {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    margin: 4px 0;
  }

  .cpe__console-body :global(.cpe__input) {
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 6px;
    color: var(--code-green);
    font-family: var(--font-code);
    font-size: 15px;
    padding: 5px 9px;
    outline: none;
    min-width: 110px;
  }

  .cpe__console-body :global(.cpe__input:focus) {
    border-color: var(--pyto-green);
  }

  .cpe__console-body :global(.cpe__submit) {
    padding: 6px 13px;
    border-radius: 8px;
    background: var(--pyto-green);
    color: #fff;
    font-weight: 800;
    font-size: 12px;
    border: none;
    cursor: pointer;
  }

  .cpe__console-body :global(.cpe__submit:hover) {
    background: var(--pyto-green-dark);
  }

  .cpe__run:disabled,
  .cpe__reset:disabled {
    opacity: 0.6;
    cursor: wait;
    transform: none;
  }

  .cpe__confetti {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    z-index: 2;
  }

  .cpe__note {
    margin-top: 16px;
    color: var(--slate);
  }

  .cpe__note code {
    color: var(--pyto-green-dark);
    font-weight: 700;
  }

  @media (max-width: 600px) {
    .cpe__header {
      justify-content: center;
      text-align: center;
    }

    .cpe__code {
      font-size: 14px;
    }
  }
</style>

<script>
  import {
    LOADING_MESSAGE,
    isFirstPyodideLoad,
    runPythonInteractive,
    friendlyError,
  } from '../scripts/pyodide-runner.js';
  import { launchConfetti } from '../scripts/confetti.js';

  const codeEl = document.getElementById('cpe-code');
  const runBtn = document.getElementById('cpe-run');
  const resetBtn = document.getElementById('cpe-reset');
  const consoleBody = document.getElementById('cpe-console-body');
  const confettiEl = document.getElementById('cpe-confetti');

  const STARTER_CODE = codeEl ? codeEl.value : '';
  let confettiFired = false;
  let hasOutput = false;

  function scrollToEnd() {
    if (consoleBody) consoleBody.scrollTop = consoleBody.scrollHeight;
  }

  function clearPlaceholder() {
    const placeholder = consoleBody?.querySelector('#cpe-placeholder');
    if (placeholder) placeholder.remove();
  }

  function resetConsole() {
    if (!consoleBody) return;
    consoleBody.innerHTML = '';
    const placeholder = document.createElement('div');
    placeholder.className = 'cpe__placeholder';
    placeholder.id = 'cpe-placeholder';
    placeholder.textContent = 'Klik ▶ Jalankan untuk menjalankan kode di atas.';
    consoleBody.appendChild(placeholder);
  }

  function appendOutputLine(text) {
    if (!consoleBody) return;
    clearPlaceholder();
    const line = document.createElement('div');
    line.className = 'cpe__line';
    line.textContent = text;
    consoleBody.appendChild(line);
    scrollToEnd();
    hasOutput = true;
  }

  function appendErrorLine(message) {
    if (!consoleBody) return;
    clearPlaceholder();
    const line = document.createElement('div');
    line.className = 'cpe__error';
    line.textContent = `💥 ${message}`;
    consoleBody.appendChild(line);
    scrollToEnd();
  }

  function appendFinalLine() {
    if (!consoleBody) return;
    clearPlaceholder();
    const line = document.createElement('div');
    line.className = 'cpe__final';
    line.textContent = '✅ Program selesai dijalankan.';
    consoleBody.appendChild(line);
    scrollToEnd();
  }

  function requestInput(promptText) {
    return new Promise((resolve) => {
      if (!consoleBody) {
        resolve('');
        return;
      }
      clearPlaceholder();

      const row = document.createElement('div');
      row.className = 'cpe__input-row';

      const promptSpan = document.createElement('span');
      promptSpan.textContent = promptText;

      const input = document.createElement('input');
      input.type = 'text';
      input.className = 'cpe__input';
      input.setAttribute('aria-label', promptText || 'Jawaban');

      const submitBtn = document.createElement('button');
      submitBtn.type = 'button';
      submitBtn.className = 'cpe__submit';
      submitBtn.textContent = 'Kirim ⏎';

      row.append(promptSpan, input, submitBtn);
      consoleBody.appendChild(row);
      scrollToEnd();
      input.focus();

      let done = false;
      const submit = () => {
        if (done) return;
        done = true;
        const value = input.value;

        const doneLine = document.createElement('div');
        doneLine.className = 'cpe__line';
        doneLine.append(document.createTextNode(promptText));
        const answerSpan = document.createElement('span');
        answerSpan.className = 'cpe__answer';
        answerSpan.textContent = value;
        doneLine.append(answerSpan);

        row.replaceWith(doneLine);
        scrollToEnd();
        resolve(value);
      };

      submitBtn.addEventListener('click', submit);
      input.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') {
          e.preventDefault();
          submit();
        }
      });
    });
  }

  async function run() {
    if (!codeEl || !runBtn) return;
    const code = codeEl.value;

    runBtn.disabled = true;
    if (resetBtn) resetBtn.disabled = true;
    hasOutput = false;
    resetConsole();
    clearPlaceholder();

    let loadingLine = null;
    if (isFirstPyodideLoad()) {
      loadingLine = document.createElement('div');
      loadingLine.className = 'cpe__line cpe__line--loading';
      loadingLine.textContent = LOADING_MESSAGE;
      consoleBody?.appendChild(loadingLine);
    }

    const clearLoading = () => {
      if (loadingLine) {
        loadingLine.remove();
        loadingLine = null;
      }
    };

    try {
      await runPythonInteractive(code, {
        onOutput: (text) => {
          clearLoading();
          appendOutputLine(text);
        },
        onInputRequest: (promptText) => {
          clearLoading();
          clearPlaceholder();
          return requestInput(promptText);
        },
      });
      clearLoading();
      appendFinalLine();

      if (!confettiFired && hasOutput) {
        confettiFired = true;
        launchConfetti(confettiEl);
      }
    } catch (err) {
      clearLoading();
      appendErrorLine(friendlyError(err));
    } finally {
      runBtn.disabled = false;
      if (resetBtn) resetBtn.disabled = false;
    }
  }

  runBtn?.addEventListener('click', run);

  resetBtn?.addEventListener('click', () => {
    if (!codeEl) return;
    codeEl.value = STARTER_CODE;
    resetConsole();
  });
</script>
