---
// Animasi #2 (plan/bab-13-animasi.md) — Centerpiece 1: foto tampil sebagai
// kartu polaroid dengan label ukurannya, sepasang penggaris mengukur lebar
// lalu tinggi, lalu .resize((300, 300)) membuat foto "menyusut" halus ke
// ukuran baru. Ini komponen ilustrasi statis (pakai foto contoh generik,
// gambar CSS, bukan foto pembaca sungguhan) — foto pembaca sungguhan tampil
// di PhotoWorkbenchEditor bagian "Coba Sendiri". Sekali jalan saat terlihat,
// boleh diulang lewat hover/klik/fokus.
---

<div
  class="prd-demo"
  data-anim="prd-demo"
  tabindex="0"
  role="button"
  aria-label="Ulangi animasi membaca ukuran foto dan resize"
>
  <div class="prd-demo__code">
    <div class="prd-demo__line">
      <span class="tok-fn">print</span>(f<span class="tok-str">&quot;Ukuran asli: {'{'}foto.size{'}'}&quot;</span>)
    </div>
    <div class="prd-demo__line">&nbsp;</div>
    <div class="prd-demo__line">
      <span class="tok-var">foto_kecil</span> = foto.<span class="prd-demo__glow tok-fn">resize</span
      >((300, 300))
    </div>
  </div>

  <div class="prd-demo__stage">
    <div class="prd-demo__polaroid prd-demo__polaroid--big">
      <span class="prd-demo__photo" aria-hidden="true">
        <span class="prd-demo__sun"></span>
        <span class="prd-demo__mountain"></span>
      </span>
      <span class="prd-demo__ruler prd-demo__ruler--w" aria-hidden="true"></span>
      <span class="prd-demo__ruler prd-demo__ruler--h" aria-hidden="true"></span>
      <span class="prd-demo__caption">1200 × 900</span>
    </div>

    <span class="prd-demo__arrow" aria-hidden="true">→</span>

    <div class="prd-demo__polaroid prd-demo__polaroid--small">
      <span class="prd-demo__photo" aria-hidden="true">
        <span class="prd-demo__sun"></span>
        <span class="prd-demo__mountain"></span>
      </span>
      <span class="prd-demo__caption">300 × 300</span>
    </div>
  </div>
</div>

<p class="prd-demo__hint">
  💡 <code>.resize((lebar, tinggi))</code> membuat <strong>salinan baru</strong> foto dengan ukuran
  yang kamu tentukan sendiri. <em>(Klik / hover untuk ulangi.)</em>
</p>

<style>
  .prd-demo {
    display: flex;
    flex-direction: column;
    gap: 18px;
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-soft);
    padding: 22px 24px;
    cursor: pointer;
  }

  .prd-demo__code {
    background: var(--code-bg);
    border-radius: var(--radius-code);
    padding: 16px 18px;
    font-family: var(--font-code);
    font-size: 13px;
    line-height: 1.85;
    color: var(--code-text);
    overflow-x: auto;
  }

  .prd-demo__line {
    white-space: pre;
  }

  .tok-var {
    color: var(--code-red);
  }

  .tok-fn {
    color: var(--code-blue);
  }

  .tok-str {
    color: var(--code-green);
  }

  .prd-demo__glow {
    border-radius: 4px;
  }

  .prd-demo.is-in .prd-demo__glow {
    animation: prd-demo-glow 0.6s ease 1.4s;
  }

  @keyframes prd-demo-glow {
    0%,
    100% {
      background: transparent;
    }
    40% {
      background: rgba(97, 175, 239, 0.28);
    }
  }

  .prd-demo__stage {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 18px;
    flex-wrap: wrap;
  }

  .prd-demo__polaroid {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 8px 8px 10px;
    box-shadow: var(--shadow-soft);
  }

  .prd-demo__photo {
    position: relative;
    display: block;
    overflow: hidden;
    border-radius: 4px;
    background: linear-gradient(180deg, var(--sky-blue) 0%, #cfe9ff 100%);
  }

  .prd-demo__polaroid--big .prd-demo__photo {
    width: 92px;
    height: 70px;
  }

  .prd-demo__polaroid--small .prd-demo__photo {
    width: 46px;
    height: 46px;
    opacity: 0;
    transform: scale(0.5);
  }

  .prd-demo.is-in .prd-demo__polaroid--small .prd-demo__photo {
    animation: prd-demo-shrink-in 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) 2s forwards;
  }

  @keyframes prd-demo-shrink-in {
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  .prd-demo__sun {
    position: absolute;
    top: 6px;
    right: 8px;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--sunny-yellow);
  }

  .prd-demo__mountain {
    position: absolute;
    bottom: -6px;
    left: 0;
    width: 0;
    height: 0;
    border-left: 26px solid transparent;
    border-right: 26px solid transparent;
    border-bottom: 26px solid var(--pyto-green-dark);
  }

  .prd-demo__ruler {
    position: absolute;
    background: var(--coral);
    opacity: 0;
  }

  .prd-demo__ruler--w {
    top: -8px;
    left: 8px;
    width: 92px;
    height: 2px;
  }

  .prd-demo__ruler--h {
    top: 8px;
    left: -8px;
    width: 2px;
    height: 70px;
  }

  .prd-demo.is-in .prd-demo__ruler--w {
    animation: prd-demo-fade-in 0.4s ease 0.6s forwards;
  }

  .prd-demo.is-in .prd-demo__ruler--h {
    animation: prd-demo-fade-in 0.4s ease 1s forwards;
  }

  @keyframes prd-demo-fade-in {
    to {
      opacity: 1;
    }
  }

  .prd-demo__caption {
    font-family: var(--font-code);
    font-size: 11px;
    font-weight: 700;
    color: var(--slate);
  }

  .prd-demo__arrow {
    font-size: 22px;
    color: var(--slate);
  }

  .prd-demo__hint {
    font-size: 14px;
    line-height: 1.55;
    margin: 0 2px;
    color: var(--slate);
  }

  .prd-demo__hint code {
    color: var(--pyto-green-dark);
    font-weight: 700;
  }

  @media (prefers-reduced-motion: reduce) {
    .prd-demo__glow,
    .prd-demo__ruler,
    .prd-demo__polaroid--small .prd-demo__photo {
      animation: none !important;
    }

    .prd-demo__ruler {
      opacity: 1;
    }

    .prd-demo__polaroid--small .prd-demo__photo {
      opacity: 1;
      transform: none;
    }
  }

  @media (max-width: 600px) {
    .prd-demo__code {
      font-size: 12px;
    }
  }
</style>

<script>
  import { observeOnce, wireReplay } from '../scripts/reveal-anim.js';

  const els = document.querySelectorAll('[data-anim="prd-demo"]');

  observeOnce(els, (el) => {
    el.classList.add('is-in');
  });

  els.forEach((el) => wireReplay(el, 'is-in'));
</script>
