---
// Animasi #10 (plan/bab-09-animasi.md): error lain yang mungkin ditemui —
// IndexError (echo Bab 8) dan ZeroDivisionError (baru). Dua gelembung error
// muncul bergantian, lalu caption penutup menegaskan triknya selalu sama:
// baca jenisnya, baca pesannya, terjemahkan. Sekali jalan saat terlihat,
// boleh diulang lewat hover/klik/fokus.
---

<div
  class="mre-demo"
  data-anim="mre-demo"
  tabindex="0"
  role="button"
  aria-label="Ulangi animasi IndexError dan ZeroDivisionError"
>
  <div class="mre-demo__code">
    <div class="mre-demo__line">
      <span class="tok-var">teman</span> = [<span class="tok-str">&quot;Kirana&quot;</span>,
      <span class="tok-str">&quot;Budi&quot;</span>, <span class="tok-str">&quot;Sari&quot;</span>]
    </div>
    <div class="mre-demo__line">
      <span class="tok-fn">print</span>(teman[<span class="tok-num">5</span>])
      <span class="mre-demo__comment"># IndexError — echo Bab 8</span>
    </div>
    <div class="mre-demo__line">&nbsp;</div>
    <div class="mre-demo__line">
      <span class="tok-var">hasil</span> = <span class="tok-num">10</span> / <span class="tok-num">0</span>
      <span class="mre-demo__comment"># ZeroDivisionError — baru!</span>
    </div>
  </div>

  <div class="mre-demo__row">
    <span class="mre-demo__error mre-demo__error--1">💥 IndexError: list index out of range</span>
    <span class="mre-demo__error mre-demo__error--2">💥 ZeroDivisionError: division by zero</span>
  </div>

  <p class="mre-demo__caption">
    Masih banyak jenis error lain di Python — tapi triknya selalu sama: baca jenisnya, baca pesannya,
    lalu terjemahkan ke bahasa sederhana seperti yang sudah kita latih di bab ini.
  </p>
</div>

<style>
  .mre-demo {
    display: flex;
    flex-direction: column;
    gap: 16px;
    cursor: pointer;
  }

  .mre-demo__code {
    background: var(--code-bg);
    border-radius: var(--radius-code);
    padding: 14px 16px;
    font-family: var(--font-code);
    font-size: 14px;
    line-height: 1.85;
    color: var(--code-text);
    overflow-x: auto;
  }

  .mre-demo__line {
    white-space: pre;
  }

  .tok-var {
    color: var(--code-red);
  }

  .tok-str {
    color: var(--code-green);
  }

  .tok-fn {
    color: var(--code-blue);
  }

  .tok-num {
    color: var(--code-orange);
  }

  .mre-demo__comment {
    color: var(--code-comment);
    margin-left: 6px;
  }

  .mre-demo__row {
    display: flex;
    flex-direction: column;
    gap: 10px;
    align-items: center;
  }

  .mre-demo__error {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: var(--code-error-bg);
    border: 1px solid var(--code-error-border);
    border-radius: 8px;
    padding: 6px 14px;
    color: var(--code-error-text);
    font-weight: 700;
    font-size: 13px;
    opacity: 0;
  }

  .mre-demo.is-in .mre-demo__error--1 {
    animation: mre-demo-fade-in 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) 0.3s forwards;
  }

  .mre-demo.is-in .mre-demo__error--2 {
    animation: mre-demo-fade-in 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) 1.3s forwards;
  }

  @keyframes mre-demo-fade-in {
    0% {
      opacity: 0;
      transform: scale(0.85);
    }
    100% {
      opacity: 1;
      transform: scale(1);
    }
  }

  .mre-demo__caption {
    max-width: 520px;
    text-align: center;
    margin: 0 auto;
    font-size: 14px;
    color: var(--ink);
    opacity: 0;
  }

  .mre-demo.is-in .mre-demo__caption {
    animation: mre-demo-caption-in 0.4s ease 2.2s forwards;
  }

  @keyframes mre-demo-caption-in {
    to {
      opacity: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .mre-demo__error,
    .mre-demo__caption {
      animation: none !important;
    }

    .mre-demo__error,
    .mre-demo__caption {
      opacity: 1;
    }
  }

  @media (max-width: 600px) {
    .mre-demo__code {
      font-size: 13px;
    }
  }
</style>

<script>
  import { observeOnce, wireReplay } from '../scripts/reveal-anim.js';

  const els = document.querySelectorAll('[data-anim="mre-demo"]');

  observeOnce(els, (el) => {
    el.classList.add('is-in');
  });

  els.forEach((el) => wireReplay(el, 'is-in'));
</script>
