---
import BaseLayout from './BaseLayout.astro';
import { chapters, isChapterAvailable } from '../data/chapters.js';

interface Props {
  currentChapter: number;
  title?: string;
  description?: string;
}

const { currentChapter, title, description } = Astro.props;

const base = import.meta.env.BASE_URL;
const current = chapters.find((c) => c.number === currentChapter);
const pageTitle =
  title ?? `Bab ${currentChapter}: ${current?.title ?? ''} — Belajar Python Bareng Pyto`;
---

<BaseLayout title={pageTitle} description={description}>
  <div class="chapter-layout">
    <!-- Sidebar (desktop): daftar semua bab, sticky di kiri -->
    <aside class="sidebar">
      <div class="sidebar__inner">
        <a href={`${base}/`} class="sidebar__brand">
          <span class="sidebar__logo" aria-hidden="true">🐍</span>
          <span class="sidebar__wordmark">
            Belajar Python<br /><span>Bareng Pyto</span>
          </span>
        </a>

        <div class="sidebar__label">Daftar Bab</div>

        <nav class="sidebar__nav" aria-label="Daftar bab">
          {
            chapters.map((chapter) => {
              const available = isChapterAvailable(chapter.number);
              const isActive = chapter.number === currentChapter;
              const Tag = available ? 'a' : 'div';
              return (
                <Tag
                  href={available ? `${base}/bab/${chapter.number}/` : undefined}
                  class={`sidebar__link ${isActive ? 'sidebar__link--active' : ''}`}
                  aria-current={isActive ? 'page' : undefined}
                >
                  <span class="sidebar__number">{chapter.number}</span>
                  <span class="sidebar__title">{chapter.title}</span>
                  {!available && <span class="sidebar__tag">Segera</span>}
                </Tag>
              );
            })
          }
        </nav>
      </div>
    </aside>

    <!-- Topbar (mobile): ganti sidebar di layar sempit -->
    <div class="topbar">
      <span class="topbar__current">
        <span class="topbar__logo" aria-hidden="true">🐍</span>
        Bab {currentChapter}
      </span>
      <a href={`${base}/`} class="topbar__all">Semua Bab →</a>
    </div>

    <main class="chapter-main">
      <article class="chapter-article">
        <slot />
      </article>
    </main>
  </div>

  <script src="../scripts/reveal.js"></script>
</BaseLayout>

<style>
  .chapter-layout {
    display: grid;
    grid-template-columns: 264px 1fr;
    align-items: start;
  }

  /* ---------------- Sidebar (desktop) ---------------- */
  .sidebar {
    position: sticky;
    top: 0;
    height: 100vh;
    overflow-y: auto;
    border-right: 1px solid var(--border);
    background: var(--white);
  }

  .sidebar__inner {
    padding: 20px 20px 32px;
  }

  .sidebar__brand {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 26px;
    text-decoration: none;
    color: var(--ink);
  }

  .sidebar__logo {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    border-radius: 12px;
    background: var(--pyto-green);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
  }

  .sidebar__wordmark {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 15px;
    line-height: 1.2;
  }

  .sidebar__wordmark span {
    font-size: 12px;
    color: var(--pyto-green-dark);
  }

  .sidebar__label {
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.6px;
    text-transform: uppercase;
    color: var(--slate);
    padding: 0 6px 10px;
  }

  .sidebar__nav {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .sidebar__link {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 10px;
    border-radius: 10px;
    text-decoration: none;
    color: var(--ink);
    font-size: 14px;
  }

  a.sidebar__link:hover {
    background: var(--cloud);
  }

  .sidebar__link--active {
    background: var(--pyto-green-soft);
    color: var(--pyto-green-dark);
    font-weight: 700;
  }

  .sidebar__number {
    flex-shrink: 0;
    width: 24px;
    height: 24px;
    border-radius: 999px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 12px;
    background: var(--cloud);
    color: var(--slate);
  }

  .sidebar__link--active .sidebar__number {
    background: var(--pyto-green);
    color: var(--white);
  }

  .sidebar__title {
    flex: 1;
    min-width: 0;
  }

  .sidebar__tag {
    flex-shrink: 0;
    font-size: 11px;
    font-weight: 700;
    padding: 3px 8px;
    border-radius: 999px;
    background: var(--cloud);
    color: var(--slate);
  }

  /* ---------------- Topbar (mobile) ---------------- */
  .topbar {
    display: none;
  }

  .chapter-main {
    min-width: 0;
  }

  .chapter-article {
    max-width: 820px;
    margin-inline: auto;
    padding: 36px 28px 90px;
    display: flex;
    flex-direction: column;
    gap: 56px;
  }

  .chapter-article :global(h2) {
    margin-bottom: 16px;
  }

  .chapter-article :global(p + p) {
    margin-top: 16px;
  }

  .chapter-article :global(section p),
  .chapter-article :global(section li) {
    color: var(--ink);
  }

  @media (max-width: 600px) {
    .chapter-article {
      padding: 28px 20px 64px;
      gap: 44px;
    }
  }

  @media (max-width: 880px) {
    .chapter-layout {
      grid-template-columns: 1fr;
    }

    .sidebar {
      display: none;
    }

    .topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      position: sticky;
      top: 0;
      z-index: 40;
      padding: 16px 20px;
      background: rgba(245, 248, 247, 0.85);
      backdrop-filter: blur(16px) saturate(160%);
      -webkit-backdrop-filter: blur(16px) saturate(160%);
      border-bottom: 1px solid var(--border);
    }

    .topbar__current {
      display: flex;
      align-items: center;
      gap: 8px;
      font-family: var(--font-heading);
      font-weight: 700;
    }

    .topbar__logo {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 28px;
      height: 28px;
      border-radius: 8px;
      background: var(--pyto-green);
      font-size: 15px;
    }

    .topbar__all {
      font-weight: 700;
      color: var(--pyto-green-dark);
      text-decoration: none;
      font-size: 14px;
      white-space: nowrap;
    }
  }
</style>
