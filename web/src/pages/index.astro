---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import EditorSection from '../components/EditorSection.astro';
import FeaturesSection from '../components/FeaturesSection.astro';
import PytoQuote from '../components/PytoQuote.astro';
import ChapterList from '../components/ChapterList.astro';
import FooterCta from '../components/FooterCta.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout>
  <Nav />
  <main>
    <Hero />
    <EditorSection />
    <FeaturesSection />
    <PytoQuote />
    <ChapterList />
  </main>
  <FooterCta />
  <Footer />

  <script src="../scripts/reveal.js"></script>
</BaseLayout>
